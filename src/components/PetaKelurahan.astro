<script>
/* ============================================================
   Peta Kelurahan Gunung Dempo
   Live Data: Google Apps Script API → Agregasi → Choropleth
   ============================================================ */
(function () {

  /* ─────────────────────────────────────────────────────────
     KONFIGURASI
  ───────────────────────────────────────────────────────── */
  const API_URL = 'https://script.googleusercontent.com/macros/echo?user_content_key=AUkAhnTCV_rOINifo-eMc4SrWQ4ihhSv8as4Zolw8_dv-S9tFT1Xbz5g4r7Pp0h0YDIGDLiJBxUNnj6V1dFFpDjXgDKvpOR56WUBYIf--6blufGgCUeyAXkVs80vjtEPPGgBxebHY0_6bgKGhWVEr4LFAxcX0igCDzl0O7_xs-2QaA6yRpGT3bixoH1sI5Nt9xHlPopxhA76fHeoljx2cMpvknGNea21r5yZA5CwLo3mvX8LYrOnvjapqZJJdmPviYToU9b34RiUPpiDKOcDbfk_0EWbEGJAVQ&lib=MDLAdFgRGOJVJ01oTM4DbJHdi3ZE4dG0b';

  /* ── GALERI PLACEHOLDER (diisi tim via Google Sheets GALERI sheet) ── */
  const GALERI_PLACEHOLDER: Record<string, GaleriItem[]> = {
    'RW 3': [
      { rw: '3', url_foto: 'https://placehold.co/400x280/10b981/ffffff?text=📋+Survei+Sanitasi', keterangan: 'Survei kondisi jamban warga RW 3', kegiatan: 'Survei Sanitasi', tanggal: '2026-07-01' },
      { rw: '3', url_foto: 'https://placehold.co/400x280/059669/ffffff?text=🦷+Penyuluhan+Gigi', keterangan: 'Edukasi kesehatan gigi & mulut door-to-door', kegiatan: 'Edukasi Kesgi', tanggal: '2026-07-02' },
      { rw: '3', url_foto: 'https://placehold.co/400x280/0284c7/ffffff?text=👶+Posyandu', keterangan: 'Pendampingan posyandu balita bersama kader', kegiatan: 'Posyandu', tanggal: '2026-07-03' },
    ],
  };

  /* ── TIPE DATA GALERI ── */
  interface GaleriItem {
    rw: string;
    url_foto: string;
    keterangan: string;
    kegiatan: string;
    tanggal: string;
  }

  /* Global galeri store (diisi saat API berhasil) */
  let galeriStore: Record<string, GaleriItem[]> = {};

  /* Warna & identitas tiap RW (statis) */
  const RW_META: Record<string, { color: string; fillBase: string; icon: string; luasHa: string }> = {
    'RW 1': { color: '#92400e', fillBase: '#f59e0b', icon: '🏘️', luasHa: '~85 Ha' },
    'RW 2': { color: '#92400e', fillBase: '#d97706', icon: '🌿', luasHa: '~62 Ha' },
    'RW 3': { color: '#065f46', fillBase: '#10b981', icon: '🏡', luasHa: '~78 Ha' },
    'RW 4': { color: '#1e40af', fillBase: '#3b82f6', icon: '🌄', luasHa: '~310 Ha' },
    'RW 5': { color: '#7c3aed', fillBase: '#8b5cf6', icon: '🏔️', luasHa: '~225 Ha' },
    'RW 6': { color: '#be185d', fillBase: '#ec4899', icon: '🌲', luasHa: '~180 Ha' },
  };

  const TILE_LAYERS = {
    carto:     { url: 'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',         sub: 'abcd', attr: '&copy; <a href="https://www.openstreetmap.org/">OSM</a> &copy; <a href="https://carto.com/">CartoDB</a>' },
    satellite: { url: 'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', sub: 'abc',  attr: '&copy; Esri World Imagery' },
  };

  /* ─────────────────────────────────────────────────────────
     GALERI: Build thumbnail strip untuk popup
  ───────────────────────────────────────────────────────── */

  /** Bersihkan URL Google Drive — pastikan format uc?id= yang benar */
  /** Bersihkan URL Google Drive → pakai thumbnail API agar bisa di-embed langsung */
  function sanitizeDriveUrl(raw: string): string {
    if (!raw) return '';
    // Coba ekstrak File ID dari berbagai format URL Drive
    let fileId = '';
    // Format: uc?id=FILE_ID  atau  ?id=FILE_ID
    const ucMatch = raw.match(/[?&]id=([^&?\s]+)/);
    if (ucMatch) fileId = ucMatch[1];
    // Format: /file/d/FILE_ID/
    if (!fileId) {
      const fileMatch = raw.match(/\/file\/d\/([^/?]+)/);
      if (fileMatch) fileId = fileMatch[1];
    }
    // Format: /d/FILE_ID/
    if (!fileId) {
      const dMatch = raw.match(/\/d\/([^/?]+)/);
      if (dMatch) fileId = dMatch[1];
    }
    if (fileId) {
      // Pakai Google Drive thumbnail API — works for embedded images, no CORS issue
      return `https://drive.google.com/thumbnail?id=${fileId}&sz=w800`;
    }
    return raw;
  }

  /** Format ISO datetime → "2 Jul 2026" */
  function formatTanggal(raw: string): string {
    if (!raw) return '';
    try {
      return new Date(raw).toLocaleDateString('id-ID', {
        day: 'numeric', month: 'short', year: 'numeric',
      });
    } catch { return raw; }
  }

  function buildGalleryStrip(rwKey: string): string {
    const items = galeriStore[rwKey] ?? [];
    if (items.length === 0) {
      return `
        <div class="popup-gallery-wrap">
          <div class="popup-gallery-label">📸 Dokumentasi Kegiatan</div>
          <p class="popup-gallery-empty">Belum ada foto. Tim KKNT sedang mendokumentasikan kegiatan di ${rwKey}.</p>
        </div>`;
    }
    const preview = items.slice(0, 4);
    const more   = items.length > 4 ? items.length - 4 : 0;
    const thumbsHtml = preview.map((item, i) => `
      <div class="popup-gallery-thumb" data-galeri-rw="${rwKey}" data-galeri-idx="${i}" title="${item.keterangan}" role="button" tabindex="0">
        <img src="${item.url_foto}" alt="${item.keterangan}" loading="lazy" onerror="this.src='https://placehold.co/62x52/f3f4f6/9ca3af?text=📷'">
        <div class="thumb-overlay">🔍</div>
      </div>`).join('');

    return `
      <div class="popup-gallery-wrap">
        <div class="popup-gallery-label">
          📸 Dokumentasi Kegiatan
          <span>${items.length} foto</span>
        </div>
        <div class="popup-gallery-strip">
          ${thumbsHtml}
          ${more > 0 ? `<div class="popup-gallery-thumb" style="display:flex;align-items:center;justify-content:center;background:#f3f4f6;font-size:.7rem;font-weight:800;color:#6b7280;cursor:pointer;" data-galeri-rw="${rwKey}" data-galeri-idx="4">+${more}</div>` : ''}
        </div>
      </div>`;
  }

  /* ─────────────────────────────────────────────────────────
     LIGHTBOX ENGINE
  ───────────────────────────────────────────────────────── */
  let lbItems: GaleriItem[] = [];
  let lbIndex = 0;

  function lbShow(items: GaleriItem[], idx: number): void {
    lbItems = items;
    lbIndex = idx;
    const overlay = document.getElementById('lb-overlay')!;
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    lbRender();
    lbBuildStrip();
  }

  function lbHide(): void {
    const overlay = document.getElementById('lb-overlay')!;
    overlay.style.display = 'none';
    document.body.style.overflow = '';
  }

  function lbRender(): void {
    const item = lbItems[lbIndex];
    if (!item) return;
    const img    = document.getElementById('lb-img')    as HTMLImageElement;
    const loader = document.getElementById('lb-img-loader')!;
    const cap    = document.getElementById('lb-caption')!;
    const date   = document.getElementById('lb-date')!;
    const act    = document.getElementById('lb-activity')!;
    const badge  = document.getElementById('lb-rw-badge')!;
    const ctr    = document.getElementById('lb-counter')!;
    const prev   = document.getElementById('lb-prev')   as HTMLButtonElement;
    const next   = document.getElementById('lb-next')   as HTMLButtonElement;

    img.classList.add('loading');
    loader.classList.remove('hidden');
    img.onload = () => { img.classList.remove('loading'); loader.classList.add('hidden'); };
    img.onerror = () => { img.src = 'https://placehold.co/800x500/f3f4f6/9ca3af?text=Foto+tidak+tersedia'; loader.classList.add('hidden'); };
    img.src    = item.url_foto;
    img.alt    = item.keterangan;
    cap.textContent  = item.keterangan;
    date.textContent = item.tanggal ? `📅 ${item.tanggal}` : '';
    act.textContent  = item.kegiatan ? `🏷️ ${item.kegiatan}` : '';
    badge.textContent = `RW ${item.rw}`;
    ctr.textContent  = `${lbIndex + 1} / ${lbItems.length}`;
    prev.disabled = lbIndex === 0;
    next.disabled = lbIndex === lbItems.length - 1;

    // Active thumb
    document.querySelectorAll('#lb-strip .lb-thumb').forEach((t, i) => {
      t.classList.toggle('active', i === lbIndex);
    });
    // Scroll active thumb into view
    const activeThumb = document.querySelector('#lb-strip .lb-thumb.active') as HTMLElement;
    if (activeThumb) activeThumb.scrollIntoView({ behavior: 'smooth', inline: 'center' });
  }

  function lbBuildStrip(): void {
    const strip = document.getElementById('lb-strip')!;
    strip.innerHTML = lbItems.map((item, i) => `
      <div class="lb-thumb ${i === lbIndex ? 'active' : ''}" data-idx="${i}" role="listitem">
        <img src="${item.url_foto}" alt="${item.keterangan}" loading="lazy" onerror="this.src='https://placehold.co/56x56/222/555?text=📷'">
      </div>`).join('');
    strip.querySelectorAll('.lb-thumb').forEach(el => {
      el.addEventListener('click', () => { lbIndex = Number(el.getAttribute('data-idx')); lbRender(); lbBuildStrip(); });
    });
  }

  function lbInitControls(): void {
    document.getElementById('lb-close')?.addEventListener('click', lbHide);
    document.getElementById('lb-prev')?.addEventListener('click', () => { if (lbIndex > 0) { lbIndex--; lbRender(); lbBuildStrip(); } });
    document.getElementById('lb-next')?.addEventListener('click', () => { if (lbIndex < lbItems.length - 1) { lbIndex++; lbRender(); lbBuildStrip(); } });
    document.getElementById('lb-overlay')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'lb-overlay') lbHide();
    });
    document.addEventListener('keydown', (e) => {
      const overlay = document.getElementById('lb-overlay');
      if (!overlay || overlay.style.display === 'none') return;
      if (e.key === 'Escape')      lbHide();
      if (e.key === 'ArrowLeft'  && lbIndex > 0)                     { lbIndex--; lbRender(); lbBuildStrip(); }
      if (e.key === 'ArrowRight' && lbIndex < lbItems.length - 1)    { lbIndex++; lbRender(); lbBuildStrip(); }
    });
  }

  /* Delegate click on dynamically created popup thumbnails */
  document.addEventListener('click', (e) => {
    const el = (e.target as HTMLElement).closest('[data-galeri-rw]') as HTMLElement | null;
    if (!el) return;
    const rw  = el.getAttribute('data-galeri-rw') ?? '';
    const idx = Number(el.getAttribute('data-galeri-idx') ?? 0);
    const items = galeriStore[rw] ?? [];
    if (items.length > 0) lbShow(items, Math.min(idx, items.length - 1));
  });

  /* ─────────────────────────────────────────────────────────
     AGREGASI DATA SURVEI
  ───────────────────────────────────────────────────────── */
  interface KKRecord {
    rw: string;
    anggota_keluarga: number;
    kelompok_rentan: string;
    kondisi_jamban: string;
    pengelolaan_sampah: string;
    keluhan_nyeri_gigi: string;
    tindakan_medis_gigi: string;
    tingkat_pengetahuan: string;
  }

  interface RWStats {
    total_kk: number;
    total_jiwa: number;
    jamban_layak: number;
    nyeri_gigi: number;
    ke_dokter: number;
    obat_warung: number;
    sampah_bakar: number;
    balita_lansia: number;
    persen_sanitasi: number;
    persen_nyeri: number;
    persen_dokter: number;
    persen_obat_warung: number;
    persen_sampah_bakar: number;
  }

  function agregasiData(rawData: KKRecord[]): Record<string, RWStats> {
    const rekap: Record<string, any> = {};

    rawData.forEach(kk => {
      const rw = `RW ${kk.rw}`;
      if (!rekap[rw]) {
        rekap[rw] = {
          total_kk: 0, total_jiwa: 0, jamban_layak: 0,
          nyeri_gigi: 0, ke_dokter: 0, obat_warung: 0,
          sampah_bakar: 0, balita_lansia: 0,
        };
      }
      const s = rekap[rw];
      s.total_kk += 1;
      s.total_jiwa += Number(kk.anggota_keluarga) || 0;
      if (kk.kondisi_jamban === 'Baik/Layak')                          s.jamban_layak += 1;
      if (kk.keluhan_nyeri_gigi === 'Ya')                              s.nyeri_gigi += 1;
      if (kk.tindakan_medis_gigi === 'Pernah ke Dokter Gigi')          s.ke_dokter += 1;
      if (kk.tindakan_medis_gigi === 'Membeli Obat Saja')              s.obat_warung += 1;
      if (kk.pengelolaan_sampah === 'Dibakar')                         s.sampah_bakar += 1;
      if (kk.kelompok_rentan === 'Bayi/Balita' || kk.kelompok_rentan === 'Lansia') s.balita_lansia += 1;
    });

    for (const rw in rekap) {
      const s = rekap[rw];
      const n = s.total_kk;
      s.persen_sanitasi    = n ? Math.round((s.jamban_layak / n) * 100) : 0;
      s.persen_nyeri       = n ? Math.round((s.nyeri_gigi / n) * 100)   : 0;
      s.persen_dokter      = n ? Math.round((s.ke_dokter / n) * 100)    : 0;
      s.persen_obat_warung = n ? Math.round((s.obat_warung / n) * 100)  : 0;
      s.persen_sampah_bakar= n ? Math.round((s.sampah_bakar / n) * 100) : 0;
    }

    return rekap as Record<string, RWStats>;
  }

  /* ─────────────────────────────────────────────────────────
     WARNA CHOROPLETH
  ───────────────────────────────────────────────────────── */
  function choroplethColor(pct: number, mode: 'sanitasi' | 'medis'): string {
    // Sanitasi: makin tinggi makin hijau
    // Medis (obat warung): makin tinggi makin merah (negatif = buruk)
    if (mode === 'sanitasi') {
      if (pct >= 90) return '#059669';
      if (pct >= 70) return '#10b981';
      if (pct >= 50) return '#fbbf24';
      return '#ef4444';
    } else {
      if (pct >= 70) return '#dc2626'; // Mayoritas obat warung = darurat
      if (pct >= 50) return '#f97316';
      if (pct >= 30) return '#fbbf24';
      return '#22c55e'; // Sedikit yang obat warung = oke
    }
  }

  /* ─────────────────────────────────────────────────────────
     BUILD POPUP
  ───────────────────────────────────────────────────────── */
  function buildPopup(
    rwKey: string,
    stats: RWStats | undefined,
    mode: 'sanitasi' | 'medis'
  ): string {
    const meta = RW_META[rwKey] ?? { color: '#059669', fillBase: '#10b981', icon: '🏘️', luasHa: '-' };

    if (!stats) {
      return `
        <div>
          <div class="popup-header" style="background: linear-gradient(135deg, ${meta.color}, ${meta.fillBase});">
            <div class="popup-rw-label">Kelurahan Gunung Dempo · KKNT 103</div>
            <div class="popup-rw-name">${meta.icon} ${rwKey}</div>
            <div class="popup-data-tag">⏳ Belum ada data survei</div>
          </div>
          <div class="popup-body">
            <p class="popup-no-data">Data survei untuk ${rwKey} belum tersedia. Tim KKNT sedang melakukan pengumpulan data di lapangan.</p>
          </div>
        </div>`;
    }

    const sanitasiColor = choroplethColor(stats.persen_sanitasi, 'sanitasi');
    const medisColor    = choroplethColor(stats.persen_obat_warung, 'medis');

    const ironiGigi = stats.persen_nyeri >= 40
      ? `⚠️ <strong>Ironi klinis:</strong> ${stats.persen_nyeri}% warga mengeluh nyeri gigi, namun ${stats.persen_obat_warung}% hanya membeli obat warung.`
      : `✅ ${stats.persen_nyeri}% warga mengalami keluhan nyeri gigi.`;

    return `
      <div>
        <div class="popup-header" style="background: linear-gradient(135deg, ${meta.color}, ${meta.fillBase});">
          <div class="popup-rw-label">Kelurahan Gunung Dempo · KKNT 103</div>
          <div class="popup-rw-name">${meta.icon} ${rwKey}</div>
          <div class="popup-data-tag">📊 ${stats.total_kk} KK · ${stats.total_jiwa} Jiwa Terdata</div>
        </div>
        <div class="popup-body">
          <div class="popup-stat-grid">
            <div class="popup-stat">
              <div class="popup-stat-val">🏠 ${stats.total_kk} KK</div>
              <div class="popup-stat-lbl">KK Tersurvei</div>
            </div>
            <div class="popup-stat">
              <div class="popup-stat-val">👥 ${stats.total_jiwa}</div>
              <div class="popup-stat-lbl">Jiwa Terdata</div>
            </div>
            <div class="popup-stat">
              <div class="popup-stat-val" style="color:${sanitasiColor}">💧 ${stats.persen_sanitasi}%</div>
              <div class="popup-stat-lbl">Sanitasi Layak</div>
            </div>
            <div class="popup-stat">
              <div class="popup-stat-val" style="color:${stats.balita_lansia > 0 ? '#f97316' : '#059669'}">
                👶 ${stats.balita_lansia} KK
              </div>
              <div class="popup-stat-lbl">Balita/Lansia</div>
            </div>
          </div>

          <div class="popup-bar-wrap">
            <div class="popup-bar-row">
              <span>🚿 Sanitasi Layak</span>
              <span style="color:${sanitasiColor};font-weight:800">${stats.persen_sanitasi}%</span>
            </div>
            <div class="popup-bar-track">
              <div class="popup-bar-fill" style="width:${stats.persen_sanitasi}%;background:${sanitasiColor};"></div>
            </div>

            <div class="popup-bar-row">
              <span>🦷 Ke Dokter Gigi</span>
              <span style="color:${stats.persen_dokter >= 50 ? '#059669' : '#ef4444'};font-weight:800">${stats.persen_dokter}%</span>
            </div>
            <div class="popup-bar-track">
              <div class="popup-bar-fill" style="width:${stats.persen_dokter}%;background:${stats.persen_dokter >= 50 ? '#059669' : '#ef4444'};"></div>
            </div>

            <div class="popup-bar-row">
              <span>🔥 Sampah Dibakar</span>
              <span style="color:${stats.persen_sampah_bakar >= 50 ? '#f97316' : '#059669'};font-weight:800">${stats.persen_sampah_bakar}%</span>
            </div>
            <div class="popup-bar-track">
              <div class="popup-bar-fill" style="width:${stats.persen_sampah_bakar}%;background:${stats.persen_sampah_bakar >= 50 ? '#f97316' : '#6ee7b7'};"></div>
            </div>
          </div>

          <div class="popup-insight">${ironiGigi}</div>
          ${buildGalleryStrip(rwKey)}
        </div>
      </div>`;
  }

  /* ─────────────────────────────────────────────────────────
     LIVE STATS BAR
  ───────────────────────────────────────────────────────── */
  function renderLiveStats(allStats: Record<string, RWStats>): void {
    const bar = document.getElementById('live-stats-bar');
    if (!bar) return;

    const totalKK   = Object.values(allStats).reduce((a, s) => a + s.total_kk, 0);
    const totalJiwa = Object.values(allStats).reduce((a, s) => a + s.total_jiwa, 0);
    const avgSanitasi = totalKK ? Math.round(Object.values(allStats).reduce((a, s) => a + s.jamban_layak, 0) / totalKK * 100) : 0;
    const avgDokter   = totalKK ? Math.round(Object.values(allStats).reduce((a, s) => a + s.ke_dokter, 0) / totalKK * 100) : 0;
    const avgNyeri    = totalKK ? Math.round(Object.values(allStats).reduce((a, s) => a + s.nyeri_gigi, 0) / totalKK * 100) : 0;
    const avgObat     = totalKK ? Math.round(Object.values(allStats).reduce((a, s) => a + s.obat_warung, 0) / totalKK * 100) : 0;

    bar.innerHTML = `
      <div class="live-stat">
        <div class="live-stat-val" style="color:#059669">${totalKK}</div>
        <div class="live-stat-lbl">KK Tersurvei</div>
        <span class="live-stat-badge badge-green">Live 🟢</span>
      </div>
      <div class="live-stat">
        <div class="live-stat-val" style="color:#1d4ed8">${totalJiwa}</div>
        <div class="live-stat-lbl">Jiwa Terdata</div>
        <span class="live-stat-badge badge-blue">Akumulatif</span>
      </div>
      <div class="live-stat">
        <div class="live-stat-val" style="color:${avgSanitasi === 100 ? '#059669' : '#f97316'}">${avgSanitasi}%</div>
        <div class="live-stat-lbl">Sanitasi Layak</div>
        <span class="live-stat-badge ${avgSanitasi >= 90 ? 'badge-green' : 'badge-yellow'}">${avgSanitasi >= 90 ? '✅ Sangat Baik' : '⚠️ Perlu Perhatian'}</span>
      </div>
      <div class="live-stat">
        <div class="live-stat-val" style="color:#dc2626">${avgNyeri}%</div>
        <div class="live-stat-lbl">Keluhan Nyeri Gigi</div>
        <span class="live-stat-badge badge-red">⚠️ Ironi Klinis</span>
      </div>
      <div class="live-stat">
        <div class="live-stat-val" style="color:${avgDokter >= 30 ? '#059669' : '#dc2626'}">${avgDokter}%</div>
        <div class="live-stat-lbl">Akses ke Dokter</div>
        <span class="live-stat-badge ${avgDokter >= 30 ? 'badge-green' : 'badge-red'}">${avgDokter >= 30 ? '✅ Cukup' : '🆘 Kritis'}</span>
      </div>
      <div class="live-stat">
        <div class="live-stat-val" style="color:#f97316">${avgObat}%</div>
        <div class="live-stat-lbl">Obat Warung</div>
        <span class="live-stat-badge badge-yellow">💊 Mandiri</span>
      </div>
    `;
    bar.style.display = 'grid';
  }

  /* ─────────────────────────────────────────────────────────
     LEGEND ITEMS
  ───────────────────────────────────────────────────────── */
  function buildLegend(): void {
    const container = document.getElementById('legend-items');
    if (!container) return;
    container.innerHTML = Object.entries(RW_META).map(([name, m]) => `
      <div class="peta-legend-item" data-rw="${name}" title="Klik untuk zoom ke ${name}">
        <span class="legend-dot" style="background:${m.fillBase};"></span>
        <span>${m.icon} ${name}</span>
      </div>`).join('');
  }

  /* ─────────────────────────────────────────────────────────
     INISIALISASI MAP
  ───────────────────────────────────────────────────────── */
  function initMap(surveyStats: Record<string, RWStats>): void {
    const loading    = document.getElementById('peta-loading');
    const statusText = document.getElementById('api-status-text');
    const mapEl      = document.getElementById('leaflet-map');
    if (!mapEl) return;

    let currentMode: 'sanitasi' | 'medis' = 'sanitasi';

    const map = (window as any).L.map('leaflet-map', {
      center: [-4.038, 103.17], zoom: 12,
      zoomControl: true, scrollWheelZoom: true,
    });

    /* Default: Satellite tile layer */
    let activeTile = (window as any).L.tileLayer(TILE_LAYERS.satellite.url, {
      attribution: TILE_LAYERS.satellite.attr,
      maxZoom: 19, subdomains: TILE_LAYERS.satellite.sub,
    }).addTo(map);

    let geojsonLayer: any = null;
    let selectedLayer: any = null;

    /* Compute choropleth fill for a feature */
    function featureStyle(feature: any, mode: 'sanitasi' | 'medis') {
      const rwKey  = `RW ${feature?.properties?.Name?.replace('RW ', '') ?? ''}`.trim();
      // Handle "RW 3" format directly
      const rwName = feature?.properties?.Name ?? '';
      const rwNum  = rwName.replace('RW ', '').trim();
      const key    = `RW ${rwNum}`;
      const stats  = surveyStats[key];
      const meta   = RW_META[key] ?? { color: '#6b7280', fillBase: '#9ca3af' };

      let fill: string;
      if (!stats) {
        fill = '#d1d5db'; // abu-abu = belum ada data
      } else {
        const pct = mode === 'sanitasi' ? stats.persen_sanitasi : stats.persen_obat_warung;
        fill = choroplethColor(pct, mode);
      }
      return { color: meta.color, weight: 2.5, opacity: 1, fillColor: fill, fillOpacity: 0.65 };
    }

    /* Load GeoJSON */
    fetch('/kelurahan-gunung-dempo.geojson')
      .then(r => r.json())
      .then((data) => {
        geojsonLayer = (window as any).L.geoJSON(data, {
          style: (f: any) => featureStyle(f, currentMode),
          onEachFeature: (feature: any, layer: any) => {
            const rwName = feature?.properties?.Name ?? '';
            const rwNum  = rwName.replace('RW ', '').trim();
            const key    = `RW ${rwNum}`;
            const meta   = RW_META[key] ?? { color: '#059669', fillBase: '#10b981' };

            layer.bindPopup(() => buildPopup(key, surveyStats[key], currentMode), {
              className: 'rw-popup', maxWidth: 300, autoPan: true,
            });

            layer.on('mouseover', () => {
              layer.setStyle({ fillOpacity: 0.85, weight: 4 });
              layer.bringToFront();
            });
            layer.on('mouseout', () => {
              if (layer !== selectedLayer) {
                layer.setStyle({ fillOpacity: 0.65, weight: 2.5 });
              }
            });
            layer.on('click', () => {
              if (selectedLayer && selectedLayer !== layer) {
                selectedLayer.setStyle({ fillOpacity: 0.65, weight: 2.5 });
              }
              selectedLayer = layer;
              layer.setStyle({ fillOpacity: 0.85, weight: 4 });
            });
          },
        }).addTo(map);

        map.fitBounds(geojsonLayer.getBounds(), { padding: [30, 30] });
        if (loading) setTimeout(() => loading.classList.add('hidden'), 300);

        /* Legend click → zoom */
        document.querySelectorAll('.peta-legend-item[data-rw]').forEach(el => {
          el.addEventListener('click', () => {
            const rw = el.getAttribute('data-rw') ?? '';
            geojsonLayer.eachLayer((layer: any) => {
              const rwName = layer.feature?.properties?.Name ?? '';
              const key = `RW ${rwName.replace('RW ', '').trim()}`;
              if (key === rw) {
                map.fitBounds(layer.getBounds(), { padding: [40, 40] });
                layer.openPopup();
              }
            });
          });
        });

        /* Mode toggle (sanitasi / medis) */
        document.querySelectorAll('.layer-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const mode = btn.getAttribute('data-mode') as 'sanitasi' | 'medis';
            currentMode = mode;

            // Update choropleth
            geojsonLayer.eachLayer((layer: any) => {
              layer.setStyle(featureStyle(layer.feature, mode));
            });
            if (selectedLayer) selectedLayer.setStyle({ fillOpacity: 0.85, weight: 4 });

            // Update choropleth legend title
            const title = document.getElementById('choro-title');
            if (title) title.textContent = mode === 'sanitasi' ? '% Sanitasi Layak' : '% Warga Obat Warung';

            // Update choro bar
            const bar = document.getElementById('choro-scale');
            if (bar) {
              if (mode === 'sanitasi') {
                bar.innerHTML = '<div class="choro-bar" style="background:linear-gradient(90deg,#ef4444,#fbbf24,#10b981);"></div>';
              } else {
                bar.innerHTML = '<div class="choro-bar" style="background:linear-gradient(90deg,#22c55e,#fbbf24,#ef4444);"></div>';
              }
            }

            // Active state
            document.querySelectorAll('.layer-btn').forEach(b => {
              b.classList.remove('active');
              b.setAttribute('aria-pressed', 'false');
            });
            btn.classList.add('active');
            btn.setAttribute('aria-pressed', 'true');
          });
        });

        /* Basemap toggle */
        document.querySelectorAll('.basemap-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const key = btn.getAttribute('data-layer') as keyof typeof TILE_LAYERS;
            const cfg = TILE_LAYERS[key];
            if (!cfg) return;
            map.removeLayer(activeTile);
            activeTile = (window as any).L.tileLayer(cfg.url, {
              attribution: cfg.attr, maxZoom: 19, subdomains: cfg.sub,
            }).addTo(map);
            if (geojsonLayer) geojsonLayer.bringToFront();
            document.querySelectorAll('.basemap-btn').forEach(b => {
              b.classList.remove('active'); b.setAttribute('aria-pressed', 'false');
            });
            btn.classList.add('active'); btn.setAttribute('aria-pressed', 'true');
          });
        });

      })
      .catch(err => {
        console.error('GeoJSON error:', err);
        if (loading) loading.innerHTML = '<p style="color:#dc2626">⚠️ Gagal memuat peta.</p>';
      });
  }

  /* ─────────────────────────────────────────────────────────
     BOOT: Fetch API → Agregasi → Render
  ───────────────────────────────────────────────────────── */
  buildLegend();

  const statusText  = document.getElementById('api-status-text');
  const loadingText = document.getElementById('loading-text');

  function boot(): void {
    if (typeof (window as any).L === 'undefined') {
      setTimeout(boot, 80);
      return;
    }

    // Init lightbox controls once
    lbInitControls();

    // Fetch live survey data
    fetch(API_URL)
      .then(r => {
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        return r.json();
      })
      .then((payload: KKRecord[] | { survei: KKRecord[]; galeri: GaleriItem[] }) => {
        // Support both old format (array) and new format ({ survei, galeri })
        let rawData: KKRecord[];
        let galeriRaw: GaleriItem[] = [];

        if (Array.isArray(payload)) {
          rawData  = payload;
        } else {
          rawData  = payload.survei  ?? [];
          galeriRaw = payload.galeri ?? [];
        }

        // Populate galeriStore from API — fallback to placeholder if empty
        if (galeriRaw.length > 0) {
          galeriRaw.forEach(item => {
            // Normalisasi: rw bisa datang sebagai angka atau string dari Sheets
            const rwStr  = String(item.rw).trim();
            const key    = `RW ${rwStr}`;
            // Bersihkan URL dan format tanggal
            const cleaned: GaleriItem = {
              ...item,
              rw:       rwStr,
              url_foto: sanitizeDriveUrl(String(item.url_foto ?? '')),
              tanggal:  formatTanggal(String(item.tanggal ?? '')),
            };
            if (!galeriStore[key]) galeriStore[key] = [];
            galeriStore[key].push(cleaned);
          });
        } else {
          // Use placeholder data until team uploads real photos
          galeriStore = { ...GALERI_PLACEHOLDER };
        }

        const stats = agregasiData(rawData);

        // Update status indicator
        if (statusText) {
          const rwCount = Object.keys(stats).length;
          const kkTotal = Object.values(stats).reduce((a, s) => a + s.total_kk, 0);
          statusText.innerHTML = `🟢 Live · ${kkTotal} KK dari ${rwCount} RW`;
        }

        initMap(stats);
      })
      .catch(err => {
        console.warn('API fetch gagal, menggunakan data statis:', err);
        if (statusText) statusText.innerHTML = '🟡 Offline · Data Statis';
        if (loadingText) loadingText.textContent = 'Memuat peta (mode offline)…';
        // Fallback: tetap render peta tanpa data survei
        initMap({});
      });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  /* Scroll reveal */
  const revealEls = document.querySelectorAll('#peta .reveal');
  new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }).observe
    ? (() => {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) { e.target.classList.add('visible'); }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
        revealEls.forEach(el => obs.observe(el));
      })()
    : revealEls.forEach(el => el.classList.add('visible'));

})();
</script>