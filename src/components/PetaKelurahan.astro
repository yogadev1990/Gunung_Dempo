---
// PetaKelurahan.astro — Leaflet.js + GeoJSON + Live Google Sheets API
---

<section class="section section-peta" id="peta" aria-labelledby="peta-title">
  <div class="container">

    <header class="section-header">
      <span class="eyebrow reveal">🗺️ Tata Ruang Kelurahan</span>
      <h2 class="section-title reveal" id="peta-title">
        Peta <span>Batas Wilayah</span>
      </h2>
      <p class="section-desc reveal">
        Peta batas wilayah Kelurahan Gunung Dempo yang telah disurvei oleh Mahasiswa KKNT 103 Kelompok 25.
        Data kesehatan ditarik secara <strong>real-time</strong> dari laporan survei lapangan.
        Klik poligon RW untuk melihat insight data mendalam.
      </p>
    </header>

    <!-- Map Widget Card -->
    <div class="peta-card reveal">

      <!-- Top Info Bar -->
      <div class="peta-info-bar">
        <div class="peta-info-item">
          <span class="peta-info-icon" aria-hidden="true">📍</span>
          <div>
            <div class="peta-info-label">Lokasi</div>
            <div class="peta-info-value">Kel. Gunung Dempo, Kec. Pagar Alam Selatan</div>
          </div>
        </div>
        <div class="peta-info-divider" aria-hidden="true"></div>
        <div class="peta-info-item">
          <span class="peta-info-icon" aria-hidden="true">🎓</span>
          <div>
            <div class="peta-info-label">Sumber Data</div>
            <div class="peta-info-value">KKNT 103 Kelompok 25 · Survei Door-to-Door</div>
          </div>
        </div>
        <div class="peta-info-divider" aria-hidden="true"></div>
        <div class="peta-info-item">
          <span class="peta-info-icon" aria-hidden="true">🔴</span>
          <div>
            <div class="peta-info-label">Status Data</div>
            <div class="peta-info-value" id="api-status-text">Menghubungkan…</div>
          </div>
        </div>
        <!-- Controls -->
        <div class="map-controls-wrap">
          <!-- Layer mode toggle -->
          <div class="layer-toggle-group" role="group" aria-label="Mode tampilan choropleth">
            <button class="layer-btn active" data-mode="sanitasi" id="btn-mode-sanitasi" aria-pressed="true">
              🚿 Sanitasi
            </button>
            <button class="layer-btn" data-mode="medis" id="btn-mode-medis" aria-pressed="false">
              🦷 Akses Medis
            </button>
          </div>
          <!-- Basemap toggle -->
          <div class="basemap-btn-group" role="group" aria-label="Pilih basemap">
            <button class="basemap-btn" data-layer="carto" aria-pressed="false">🗺️ Minimal</button>
            <button class="basemap-btn active" data-layer="satellite" aria-pressed="true">🛰️ Satelit</button>
          </div>
        </div>
      </div>


      <!-- Map Container -->
      <div class="peta-map-wrap">
        <div class="peta-map-overlay-loading" id="peta-loading" aria-live="polite">
          <div class="peta-spinner" aria-hidden="true"></div>
          <p id="loading-text">Memuat data survei & peta wilayah…</p>
        </div>
        <div id="leaflet-map" aria-label="Peta interaktif choropleth batas wilayah Kelurahan Gunung Dempo"></div>
      </div>

      <!-- Choropleth Scale Legend -->
      <div class="choropleth-legend" id="choropleth-legend">
        <span class="choro-label">Rendah</span>
        <div class="choro-scale" id="choro-scale">
          <div class="choro-bar" style="background: linear-gradient(90deg, #10b981, #fbbf24, #ef4444);"></div>
        </div>
        <span class="choro-label">Tinggi</span>
        <span class="choro-title" id="choro-title">% Sanitasi Layak</span>
      </div>

      <!-- Bottom: Legend + Info -->
      <div class="peta-legend">
        <div class="peta-legend-left">
          <div class="peta-legend-title"><span>🗂️</span> RW Kelurahan</div>
          <div class="peta-legend-items" id="legend-items"><!-- JS injected --></div>
        </div>
        <div class="peta-legend-right">
          <p class="peta-legend-note">
            <strong>💡 Tips:</strong> Klik poligon RW untuk insight survei. Toggle mode peta untuk
            melihat <em>Sanitasi</em> vs <em>Akses Medis Gigi</em>. Data di-update otomatis dari Google Sheets.
          </p>
          <div class="peta-tech-badge">
            <span>⚡</span><strong>Leaflet.js</strong>
            <span>+</span><strong>GeoJSON</strong>
            <span>+</span><strong>Apps Script API</strong>
          </div>
        </div>
      </div>

    </div><!-- /peta-card -->
  </div>
</section>

<!-- Wave Divider -->
<div class="wave-divider" aria-hidden="true" style="background: var(--clr-mist);">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,20 C360,60 720,0 1080,30 C1260,45 1380,15 1440,20 L1440,60 L0,60 Z" fill="#ffffff"/>
  </svg>
</div>

<!-- ===== LIGHTBOX MODAL ===== -->
<div id="lb-overlay" class="lb-overlay" role="dialog" aria-modal="true" aria-label="Galeri dokumentasi" style="display:none;">
  <button class="lb-close" id="lb-close" aria-label="Tutup galeri">✕</button>
  <button class="lb-nav lb-prev" id="lb-prev" aria-label="Foto sebelumnya">‹</button>
  <button class="lb-nav lb-next" id="lb-next" aria-label="Foto berikutnya">›</button>

  <div class="lb-content">
    <div class="lb-img-wrap">
      <img id="lb-img" src="" alt="" class="lb-img" loading="lazy"/>
      <div class="lb-img-loader" id="lb-img-loader" aria-hidden="true">
        <div class="lb-spinner"></div>
      </div>
    </div>
    <div class="lb-meta">
      <div class="lb-meta-top">
        <span class="lb-rw-badge" id="lb-rw-badge"></span>
        <span class="lb-activity" id="lb-activity"></span>
        <span class="lb-counter" id="lb-counter"></span>
      </div>
      <p class="lb-caption" id="lb-caption"></p>
      <p class="lb-date" id="lb-date"></p>
    </div>
    <!-- Thumbnail strip -->
    <div class="lb-strip" id="lb-strip" role="list" aria-label="Semua foto"></div>
  </div>
</div>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>

<style>
  /* ===== Section ===== */
  .section-peta {
    padding: 5rem 0 3rem;
    background: var(--clr-mist, #f0fdf4);
  }

  /* ===== Card ===== */
  .peta-card {
    background: #fff;
    border-radius: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,.07), 0 20px 60px -10px rgba(5,150,105,.12);
    overflow: hidden;
    border: 1px solid rgba(5,150,105,.1);
    transition: box-shadow .3s ease;
  }
  .peta-card:hover {
    box-shadow: 0 8px 12px -2px rgba(0,0,0,.1), 0 30px 80px -10px rgba(5,150,105,.2);
  }

  /* ===== Info Bar ===== */
  .peta-info-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: .875rem 1.25rem;
    gap: 0;
    background: linear-gradient(135deg,#f0fdf4,#ecfdf5);
    border-bottom: 1px solid rgba(5,150,105,.15);
  }
  .peta-info-item {
    display: flex;
    align-items: center;
    gap: .625rem;
    padding: .4rem 1rem;
    flex: 1;
    min-width: 160px;
  }
  .peta-info-icon { font-size: 1.2rem; flex-shrink: 0; }
  .peta-info-label {
    font-size: .62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em;
    color: #6b7280; margin-bottom: .1rem;
  }
  .peta-info-value { font-size: .76rem; font-weight: 600; color: #111827; }
  .peta-info-divider { width: 1px; height: 2.25rem; background: rgba(5,150,105,.2); flex-shrink: 0; }

  /* ===== Controls ===== */
  .map-controls-wrap {
    display: flex;
    align-items: center;
    gap: .5rem;
    margin-left: auto;
    padding-left: 1rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }
  .layer-toggle-group, .basemap-btn-group { display: flex; gap: .25rem; }

  .layer-btn, .basemap-btn {
    padding: .35rem .7rem;
    font-size: .72rem; font-weight: 600;
    border: 1.5px solid rgba(5,150,105,.3);
    border-radius: .5rem;
    background: white; color: #374151;
    cursor: pointer;
    transition: all .2s ease;
    white-space: nowrap;
  }
  .layer-btn:hover, .basemap-btn:hover {
    border-color: #059669; color: #059669; background: #f0fdf4;
  }
  .layer-btn.active {
    background: linear-gradient(135deg,#059669,#10b981);
    color: white; border-color: transparent;
    box-shadow: 0 2px 8px rgba(5,150,105,.35);
  }
  .basemap-btn.active {
    background: linear-gradient(135deg,#1e40af,#3b82f6);
    color: white; border-color: transparent;
    box-shadow: 0 2px 8px rgba(30,64,175,.35);
  }

  /* ===== Live Stats Bar ===== */
  .live-stats-bar {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 0;
    border-bottom: 1px solid rgba(5,150,105,.12);
    background: #fff;
  }
  .live-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: .7rem .5rem;
    border-right: 1px solid #f0f0f0;
    text-align: center;
    transition: background .2s ease;
  }
  .live-stat:last-child { border-right: none; }
  .live-stat:hover { background: #f9fafb; }
  .live-stat-val {
    font-size: 1.25rem; font-weight: 900;
    line-height: 1.1; letter-spacing: -.02em;
  }
  .live-stat-lbl {
    font-size: .6rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .05em;
    color: #9ca3af; margin-top: .2rem;
  }
  .live-stat-badge {
    font-size: .58rem; font-weight: 700;
    padding: .1rem .35rem;
    border-radius: .25rem;
    margin-top: .2rem;
    display: inline-block;
  }
  .badge-green { background: #d1fae5; color: #065f46; }
  .badge-red   { background: #fee2e2; color: #991b1b; }
  .badge-yellow { background: #fef3c7; color: #92400e; }
  .badge-blue  { background: #dbeafe; color: #1e40af; }

  /* ===== Map Container ===== */
  .peta-map-wrap {
    position: relative; width: 100%; height: 520px; background: #e8f5e9;
  }
  #leaflet-map { width: 100%; height: 100%; z-index: 1; }
  .peta-map-overlay-loading {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    background: linear-gradient(135deg,#f0fdf4,#ecfdf5);
    z-index: 10; gap: 1rem; color: #059669;
    font-weight: 600; font-size: .9rem;
    transition: opacity .5s ease;
  }
  .peta-map-overlay-loading.hidden { opacity: 0; pointer-events: none; }
  .peta-spinner {
    width: 44px; height: 44px;
    border: 4px solid rgba(5,150,105,.2);
    border-top-color: #059669;
    border-radius: 50%; animation: spin .8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ===== Choropleth Legend ===== */
  .choropleth-legend {
    display: flex;
    align-items: center;
    gap: .6rem;
    padding: .5rem 1.5rem;
    background: #f9fafb;
    border-top: 1px solid #f0f0f0;
    border-bottom: 1px solid #f0f0f0;
  }
  .choro-label { font-size: .65rem; font-weight: 700; color: #6b7280; white-space: nowrap; }
  .choro-scale { flex: 1; }
  .choro-bar { height: 10px; border-radius: 999px; }
  .choro-title {
    font-size: .65rem; font-weight: 800;
    color: #374151; text-transform: uppercase;
    letter-spacing: .05em; white-space: nowrap; margin-left: auto;
  }

  /* ===== Legend ===== */
  .peta-legend {
    display: flex; gap: 1.5rem;
    padding: 1rem 1.5rem 1.25rem;
    background: #fafafa;
    border-top: 1px solid #f0f0f0;
    flex-wrap: wrap;
  }
  .peta-legend-left { flex: 1; min-width: 220px; }
  .peta-legend-right { flex: 1; min-width: 200px; }
  .peta-legend-title {
    font-size: .72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em;
    color: #374151; margin-bottom: .6rem;
    display: flex; align-items: center; gap: .35rem;
  }
  .peta-legend-items { display: flex; flex-wrap: wrap; gap: .4rem 1.25rem; }
  .peta-legend-item {
    display: flex; align-items: center; gap: .4rem;
    font-size: .73rem; color: #374151; font-weight: 500;
    cursor: pointer; padding: .2rem .4rem;
    border-radius: .35rem; transition: background .15s ease;
  }
  .peta-legend-item:hover { background: #f3f4f6; }
  .legend-dot {
    width: 12px; height: 12px; border-radius: 3px;
    flex-shrink: 0; box-shadow: 0 1px 3px rgba(0,0,0,.15);
  }
  .peta-legend-note { font-size: .7rem; color: #6b7280; line-height: 1.6; margin: 0 0 .6rem; }
  .peta-tech-badge {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .68rem; color: #9ca3af;
    background: #f3f4f6; padding: .25rem .6rem;
    border-radius: .4rem; border: 1px solid #e5e7eb;
  }
  .peta-tech-badge strong { color: #374151; }

  /* ===== Leaflet Custom Popup ===== */
  :global(.rw-popup .leaflet-popup-content-wrapper) {
    border-radius: .875rem !important;
    padding: 0 !important; overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,.18) !important;
    border: none !important; min-width: 260px;
  }
  :global(.rw-popup .leaflet-popup-content) { margin: 0 !important; width: 100% !important; }
  :global(.popup-header) { padding: .875rem 1rem .625rem; color: white; }
  :global(.popup-rw-label) {
    font-size: .62rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; opacity: .85; margin-bottom: .15rem;
  }
  :global(.popup-rw-name) { font-size: 1.1rem; font-weight: 800; }
  :global(.popup-data-tag) {
    display: inline-flex; align-items: center; gap: .25rem;
    font-size: .6rem; font-weight: 700; padding: .15rem .4rem;
    border-radius: .25rem; background: rgba(255,255,255,.2);
    margin-top: .35rem; backdrop-filter: blur(4px);
  }
  :global(.popup-body) { padding: .75rem 1rem .875rem; background: white; }
  :global(.popup-stat-grid) {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: .4rem; margin-bottom: .6rem;
  }
  :global(.popup-stat) {
    background: #f9fafb; border-radius: .5rem;
    padding: .4rem .5rem; border: 1px solid #f0f0f0;
  }
  :global(.popup-stat-val) { font-size: .88rem; font-weight: 800; color: #111827; line-height: 1.2; }
  :global(.popup-stat-lbl) {
    font-size: .58rem; color: #9ca3af; font-weight: 600;
    text-transform: uppercase; letter-spacing: .04em;
  }
  :global(.popup-bar-wrap) { margin-top: .5rem; }
  :global(.popup-bar-row) {
    display: flex; justify-content: space-between;
    font-size: .63rem; color: #6b7280;
    margin-bottom: .2rem; font-weight: 600;
  }
  :global(.popup-bar-track) { height: 7px; background: #f3f4f6; border-radius: 999px; overflow: hidden; margin-bottom: .35rem; }
  :global(.popup-bar-fill) { height: 100%; border-radius: 999px; }
  :global(.popup-insight) {
    font-size: .68rem; color: #374151; line-height: 1.55;
    margin: .5rem 0 0; padding: .45rem .55rem;
    background: #fef3c7; border-left: 3px solid #f59e0b;
    border-radius: 0 .35rem .35rem 0;
  }
  :global(.popup-no-data) {
    font-size: .72rem; color: #9ca3af; text-align: center;
    padding: .75rem; font-style: italic;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .peta-info-bar { flex-direction: column; align-items: flex-start; gap: .4rem; }
    .peta-info-divider { display: none; }
    .peta-info-item { padding: .3rem 0; min-width: unset; }
    .map-controls-wrap { margin-left: 0; padding-left: 0; width: 100%; }
    .peta-map-wrap { height: 380px; }
    .peta-legend { flex-direction: column; }
    .choropleth-legend { flex-wrap: wrap; gap: .4rem; }
  }

  /* ===== LIGHTBOX MODAL ===== */
  .lb-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.92);
    display: flex; align-items: center; justify-content: center;
    padding: 1rem;
    animation: lbFadeIn .25s ease;
  }
  @keyframes lbFadeIn { from { opacity: 0; } to { opacity: 1; } }

  .lb-content {
    display: flex; flex-direction: column;
    max-width: 860px; width: 100%; max-height: 92vh;
    gap: .75rem;
  }
  .lb-img-wrap {
    position: relative;
    flex: 1; min-height: 0;
    background: #111;
    border-radius: .875rem;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .lb-img {
    max-width: 100%; max-height: 58vh;
    object-fit: contain;
    border-radius: .875rem;
    transition: opacity .3s ease;
  }
  .lb-img.loading { opacity: 0; }
  .lb-img-loader {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none;
  }
  .lb-img-loader.hidden { display: none; }
  .lb-spinner {
    width: 36px; height: 36px;
    border: 3px solid rgba(255,255,255,.2);
    border-top-color: #fff;
    border-radius: 50%; animation: spin .7s linear infinite;
  }

  .lb-meta {
    color: #fff; padding: 0 .25rem;
  }
  .lb-meta-top {
    display: flex; align-items: center; gap: .5rem; flex-wrap: wrap;
    margin-bottom: .35rem;
  }
  .lb-rw-badge {
    font-size: .68rem; font-weight: 800; padding: .2rem .55rem;
    background: rgba(255,255,255,.15); border-radius: .35rem;
    backdrop-filter: blur(4px);
  }
  .lb-activity {
    font-size: .68rem; font-weight: 700; padding: .2rem .55rem;
    background: rgba(16,185,129,.25); color: #6ee7b7;
    border-radius: .35rem;
  }
  .lb-counter {
    margin-left: auto;
    font-size: .7rem; color: rgba(255,255,255,.5); font-weight: 600;
  }
  .lb-caption { font-size: .85rem; font-weight: 600; margin: 0 0 .15rem; line-height: 1.4; }
  .lb-date { font-size: .7rem; color: rgba(255,255,255,.45); margin: 0; }

  /* Thumbnail strip */
  .lb-strip {
    display: flex; gap: .4rem; overflow-x: auto;
    padding: .35rem 0; scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,.2) transparent;
  }
  .lb-thumb {
    width: 56px; height: 56px; flex-shrink: 0;
    border-radius: .4rem; overflow: hidden;
    cursor: pointer; border: 2.5px solid transparent;
    transition: border-color .2s, transform .2s;
    background: #222;
  }
  .lb-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .lb-thumb.active { border-color: #10b981; transform: scale(1.08); }
  .lb-thumb:hover { border-color: rgba(255,255,255,.5); }

  /* Nav buttons */
  .lb-close {
    position: fixed; top: 1rem; right: 1rem;
    width: 40px; height: 40px;
    background: rgba(255,255,255,.12); backdrop-filter: blur(8px);
    border: none; border-radius: 50%;
    color: white; font-size: 1.1rem;
    cursor: pointer; z-index: 10000;
    transition: background .2s ease;
    display: flex; align-items: center; justify-content: center;
  }
  .lb-close:hover { background: rgba(255,255,255,.25); }
  .lb-nav {
    position: fixed; top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px;
    background: rgba(255,255,255,.12); backdrop-filter: blur(8px);
    border: none; border-radius: 50%;
    color: white; font-size: 1.6rem;
    cursor: pointer; z-index: 10000;
    transition: background .2s ease;
    display: flex; align-items: center; justify-content: center;
  }
  .lb-nav:hover { background: rgba(255,255,255,.25); }
  .lb-prev { left: 1rem; }
  .lb-next { right: 1rem; }
  .lb-nav:disabled { opacity: .3; cursor: default; }

  /* Popup gallery strip */
  :global(.popup-gallery-wrap) {
    margin-top: .6rem;
    border-top: 1px solid #f0f0f0;
    padding-top: .6rem;
  }
  :global(.popup-gallery-label) {
    font-size: .62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .05em;
    color: #6b7280; margin-bottom: .4rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  :global(.popup-gallery-label span) { color: #9ca3af; font-weight: 500; }
  :global(.popup-gallery-strip) {
    display: flex; gap: .35rem; overflow-x: auto;
    scrollbar-width: thin; scrollbar-color: #e5e7eb transparent;
  }
  :global(.popup-gallery-thumb) {
    width: 62px; height: 52px; flex-shrink: 0;
    border-radius: .4rem; overflow: hidden;
    cursor: pointer; border: 2px solid #f0f0f0;
    transition: border-color .2s, transform .15s;
    background: #f3f4f6;
    position: relative;
  }
  :global(.popup-gallery-thumb img) {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }
  :global(.popup-gallery-thumb:hover) {
    border-color: #10b981; transform: scale(1.06);
  }
  :global(.popup-gallery-thumb .thumb-overlay) {
    position: absolute; inset: 0;
    background: rgba(0,0,0,.4);
    display: flex; align-items: center; justify-content: center;
    font-size: .65rem; color: white; font-weight: 700;
    opacity: 0; transition: opacity .2s;
  }
  :global(.popup-gallery-thumb:hover .thumb-overlay) { opacity: 1; }
  :global(.popup-gallery-empty) {
    font-size: .68rem; color: #9ca3af; font-style: italic; padding: .25rem 0;
  }
  :global(.popup-gallery-btn) {
