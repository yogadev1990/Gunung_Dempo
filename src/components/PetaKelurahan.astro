---
// PetaKelurahan.astro
---

<section class="section section-peta" id="peta" aria-labelledby="peta-title">
  <div class="container">

    <header class="section-header">
      <span class="eyebrow reveal">🗺️ Tata Ruang Kelurahan</span>
      <h2 class="section-title reveal" id="peta-title">
        Peta <span>Batas Kelurahan</span>
      </h2>
      <p class="section-desc reveal">
        Peta batas wilayah Kelurahan Gunung Dempo yang telah di survei oleh Mahasiswa KKNT 103 kelompok 25. Klik peta untuk menjelajahi setiap wilayah RW dan batas kelurahan secara interaktif.
      </p>
    </header>

    <!-- Map Widget Card -->
    <div class="peta-card reveal">

      <!-- Top Info Bar -->
      <div class="peta-info-bar">
        <div class="peta-info-item">
          <span class="peta-info-icon" aria-hidden="true">📍</span>
          <div>
            <div class="peta-info-label">Lokasi</div>
            <div class="peta-info-value">Kel. Gunung Dempo, Kec. Pagar Alam Selatan</div>
          </div>
        </div>
        <div class="peta-info-divider" aria-hidden="true"></div>
        <div class="peta-info-item">
          <span class="peta-info-icon" aria-hidden="true">🏛️</span>
          <div>
            <div class="peta-info-label">Sumber Data</div>
            <div class="peta-info-value">Mahasiswa KKNT 103 Kelompok 25</div>
          </div>
        </div>
        <div class="peta-info-divider" aria-hidden="true"></div>
        <div class="peta-info-item">
          <span class="peta-info-icon" aria-hidden="true">🏘️</span>
          <div>
            <div class="peta-info-label">Rukun Warga</div>
            <div class="peta-info-value">6 RW · Batas Wilayah Terverifikasi</div>
          </div>
        </div>
        <!-- Open in Maps Button -->
        <a
          href="https://www.google.com/maps/d/viewer?mid=1qz_pBCJ2iL9_IV9BW37LyN8p4LgZZls"
          target="_blank"
          rel="noopener noreferrer"
          class="peta-open-btn"
          id="btn-open-map"
          aria-label="Buka peta di Google Maps"
        >
          <span aria-hidden="true">↗</span> Buka di Maps
        </a>
      </div>

      <!-- Map Embed Container -->
      <div class="peta-map-wrap" id="peta-map-wrap">
        <div class="peta-map-overlay-loading" id="peta-loading" aria-live="polite">
          <div class="peta-spinner" aria-hidden="true"></div>
          <p>Memuat peta wilayah…</p>
        </div>
        <iframe
          id="peta-iframe"
          src="https://www.google.com/maps/d/embed?mid=1qz_pBCJ2iL9_IV9BW37LyN8p4LgZZls&ehbc=2E312F"
          title="Peta Batas Wilayah Kelurahan Gunung Dempo"
          allow="fullscreen"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          aria-label="Peta interaktif batas wilayah Kelurahan Gunung Dempo"
        ></iframe>
      </div>

      <!-- Bottom Legend -->
      <div class="peta-legend">
        <div class="peta-legend-title">
          <span aria-hidden="true">🗂️</span> Keterangan Peta
        </div>
        <div class="peta-legend-items">
          <div class="peta-legend-item">
            <span class="legend-dot" style="background: #eab308;"></span>
            <span>RW 1 : 103,1919545°E 4,0253011°S</span>
          </div>
          <div class="peta-legend-item">
            <span class="legend-dot" style="background: #d97706;"></span>
            <span>RW 2 : 103,1806522°E 4,0330292°S</span>
          </div>
          <div class="peta-legend-item">
            <span class="legend-dot" style="background: #15803d;"></span>
            <span>RW 3 : 103,1907260°E 4,0385264°S</span>
          </div>
          <div class="peta-legend-item">
            <span class="legend-dot" style="background: #4ade80;"></span>
            <span>RW 4 : 103,1569263°E 4,0262073°S</span>
          </div>
          <div class="peta-legend-item">
            <span class="legend-dot" style="background: #dc2626;"></span>
            <span>RW 5 : 103,1585554°E 4,0412606°S</span>
          </div>
          <div class="peta-legend-item">
            <span class="legend-dot" style="background: #9333ea;"></span>
            <span>RW 6 : 103,1512287°E 4,0603674°S</span>
          </div>
        </div>
        <p class="peta-legend-note">
          * Peta bersumber dari Google Maps MyMaps.
        </p>
      </div>

    </div>
    <!-- /peta-card -->

  </div>
</section>

<!-- Wave Divider -->
<div class="wave-divider" aria-hidden="true" style="background: var(--clr-mist);">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,20 C360,60 720,0 1080,30 C1260,45 1380,15 1440,20 L1440,60 L0,60 Z" fill="#ffffff"/>
  </svg>
</div>

<style>
  /* ===== Section ===== */
  .section-peta {
    padding: 5rem 0 3rem;
    background: var(--clr-mist, #f0fdf4);
  }

  /* ===== Card Container ===== */
  .peta-card {
    background: #ffffff;
    border-radius: 1.5rem;
    box-shadow:
      0 4px 6px -1px rgba(0,0,0,0.07),
      0 20px 60px -10px rgba(5, 150, 105, 0.12);
    overflow: hidden;
    border: 1px solid rgba(5, 150, 105, 0.1);
    transition: box-shadow 0.3s ease;
  }
  .peta-card:hover {
    box-shadow:
      0 8px 12px -2px rgba(0,0,0,0.1),
      0 30px 80px -10px rgba(5, 150, 105, 0.2);
  }

  /* ===== Info Bar ===== */
  .peta-info-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
    border-bottom: 1px solid rgba(5, 150, 105, 0.15);
  }
  .peta-info-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 1.25rem;
    flex: 1;
    min-width: 160px;
  }
  .peta-info-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  .peta-info-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6b7280;
    margin-bottom: 0.1rem;
  }
  .peta-info-value {
    font-size: 0.78rem;
    font-weight: 600;
    color: #111827;
  }
  .peta-info-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(5, 150, 105, 0.2);
    flex-shrink: 0;
  }

  /* Open Maps Button */
  .peta-open-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    padding: 0.5rem 1.1rem;
    background: linear-gradient(135deg, #059669, #10b981);
    color: #ffffff;
    border-radius: 0.625rem;
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(5, 150, 105, 0.35);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    flex-shrink: 0;
  }
  .peta-open-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(5, 150, 105, 0.45);
    background: linear-gradient(135deg, #047857, #059669);
  }

  /* ===== Map Embed ===== */
  .peta-map-wrap {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    background: #e8f5e9;
    overflow: hidden;
  }
  .peta-map-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Loading Overlay */
  .peta-map-overlay-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #f0fdf4;
    z-index: 2;
    gap: 1rem;
    color: #059669;
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity 0.4s ease;
  }
  .peta-map-overlay-loading.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .peta-spinner {
    width: 40px;
    height: 40px;
    border: 4px solid rgba(5, 150, 105, 0.2);
    border-top-color: #059669;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ===== Legend ===== */
  .peta-legend {
    padding: 1rem 1.5rem 1.25rem;
    background: #fafafa;
    border-top: 1px solid #f0f0f0;
  }
  .peta-legend-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #374151;
    margin-bottom: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .peta-legend-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    margin-bottom: 0.6rem;
  }
  .peta-legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: #4b5563;
  }
  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .peta-legend-note {
    font-size: 0.68rem;
    color: #9ca3af;
    margin: 0;
    line-height: 1.5;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .peta-info-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .peta-info-divider {
      display: none;
    }
    .peta-info-item {
      padding: 0.35rem 0.25rem;
      min-width: unset;
    }
    .peta-open-btn {
      margin-left: 0;
      width: 100%;
      justify-content: center;
      margin-top: 0.35rem;
    }
    .peta-map-wrap {
      padding-bottom: 75%; /* taller on mobile */
    }
    .peta-legend-items {
      gap: 0.4rem 0.75rem;
    }
  }
</style>

<script>
  /* Hide loading overlay once iframe has loaded */
  const iframe = document.getElementById('peta-iframe') as HTMLIFrameElement | null;
  const loading = document.getElementById('peta-loading');

  if (iframe && loading) {
    iframe.addEventListener('load', () => {
      loading.classList.add('hidden');
    });
    /* Fallback: hide after 8 seconds in case load event doesn't fire */
    setTimeout(() => loading.classList.add('hidden'), 8000);
  }

  /* Scroll Reveal (reuse pattern from other sections) */
  const revealEls = document.querySelectorAll('#peta .reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

  revealEls.forEach(el => observer.observe(el));
</script>