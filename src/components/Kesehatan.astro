---
// Kesehatan.astro
---

<section class="section section-sehat" id="sehat" aria-labelledby="sehat-title">
  <div class="container">

    <header class="section-header">
      <span class="eyebrow reveal">🏥 Desa Sehat</span>
      <h2 class="section-title reveal" id="sehat-title">
        Data <span>Kesehatan</span> Masyarakat
      </h2>
      <p class="section-desc reveal">
        Hasil survei dan pendataan lapangan program KKNT 103 Kelompok 25 menggambarkan kondisi
        kesehatan warga Kelurahan Gunung Dempo yang semakin baik.
      </p>
    </header>

    <!-- ===== LIVE DATA SURVEI LAPANGAN ===== -->
    <div class="live-survey-wrap reveal">
      <div class="live-survey-header">
        <div class="live-survey-title">
          <span class="live-dot" aria-hidden="true"></span>
          <strong>Data Survei Real-Time</strong>
          <span class="live-survey-sub">Door-to-Door · KKNT 103 Kelompok 25</span>
        </div>
        <span class="live-survey-status" id="kes-api-status">⏳ Menghubungkan…</span>
      </div>
      <div class="live-survey-grid" id="kes-stats-grid">
        <!-- Skeleton loading -->
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
      </div>
    </div>

    <div class="health-grid">

      <!-- Card 1: Kesehatan Gigi & Mulut -->
      <article
        class="health-card reveal reveal-delay-1"
        id="card-gigi"
        style="--card-accent: linear-gradient(90deg, #059669, #34d399);"
      >
        <div class="health-card-icon" style="--icon-bg: #d1fae5;" aria-hidden="true">🦷</div>
        <p class="health-card-eyebrow">Kesehatan Gigi &amp; Mulut</p>
        <h3 class="health-card-title">Kebiasaan Sikat Gigi Warga</h3>

        <div class="pictogram-row" role="img" aria-label="8 dari 10 warga sudah sikat gigi 2 kali sehari">
          <!-- 8 aktif, 2 abu-abu -->
          <span class="pictogram-item" title="Sikat gigi rutin">😁</span>
          <span class="pictogram-item" title="Sikat gigi rutin">😁</span>
          <span class="pictogram-item" title="Sikat gigi rutin">😁</span>
          <span class="pictogram-item" title="Sikat gigi rutin">😁</span>
          <span class="pictogram-item" title="Sikat gigi rutin">😁</span>
          <span class="pictogram-item" title="Sikat gigi rutin">😁</span>
          <span class="pictogram-item" title="Sikat gigi rutin">😁</span>
          <span class="pictogram-item" title="Sikat gigi rutin">😁</span>
          <span class="pictogram-item" style="opacity:0.25;" title="Belum rutin">😶</span>
          <span class="pictogram-item" style="opacity:0.25;" title="Belum rutin">😶</span>
        </div>

        <p class="pictogram-label">
          <strong>8 dari 10</strong> warga sudah sikat gigi 2× sehari (pagi &amp; malam).
        </p>

        <!-- Progress Bar -->
        <div style="margin-top:1rem;">
          <div style="display:flex;justify-content:space-between;font-size:0.75rem;color:var(--clr-gray-400);margin-bottom:0.35rem;">
            <span>Rutin Sikat Gigi</span><span>80%</span>
          </div>
          <div class="rw-progress-bar">
            <div class="rw-progress-fill" data-width="80%"></div>
          </div>
        </div>
      </article>

      <!-- Card 2: Sanitasi -->
      <article
        class="health-card reveal reveal-delay-2"
        id="card-sanitasi"
        style="--card-accent: linear-gradient(90deg, #0284c7, #38bdf8);"
      >
        <div class="health-card-icon" style="--icon-bg: #e0f2fe;" aria-hidden="true">🚿</div>
        <p class="health-card-eyebrow">Sanitasi &amp; Lingkungan</p>
        <h3 class="health-card-title">Fasilitas Jamban &amp; Sanitasi Bersih</h3>

        <div class="pct-ring-wrap">
          <!-- SVG Ring Chart -->
          <svg class="pct-ring" viewBox="0 0 90 90" role="img" aria-label="90% rumah memiliki jamban sehat">
            <circle cx="45" cy="45" r="36" fill="none" stroke="#e0f2fe" stroke-width="9"/>
            <circle
              cx="45" cy="45" r="36" fill="none" stroke="#0284c7" stroke-width="9"
              stroke-dasharray="226.2" stroke-dashoffset="22.6"
              stroke-linecap="round"
              transform="rotate(-90 45 45)"
              style="transition: stroke-dashoffset 1.5s ease;"
            />
            <text x="45" y="50" text-anchor="middle" font-size="14" font-weight="800" fill="#0369a1">90%</text>
          </svg>
          <div class="pct-ring-text">
            <div class="pct-ring-value" style="color:#0284c7;">90%</div>
            <div class="pct-ring-desc">Rumah tangga memiliki jamban sehat &amp; akses air bersih yang layak.</div>
          </div>
        </div>

        <!-- Pictogram houses -->
        <div class="pictogram-row" role="img" aria-label="9 dari 10 rumah memiliki sanitasi baik" style="margin-top:0.75rem;">
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item" style="opacity:0.25;">🏚️</span>
        </div>
      </article>

      <!-- Card 2: Sanitasi -->
      <article
        class="health-card reveal reveal-delay-2"
        id="card-sanitasi"
        style="--card-accent: linear-gradient(90deg, #0284c7, #38bdf8);"
      >
        <div class="health-card-icon" style="--icon-bg: #e0f2fe;" aria-hidden="true">🗑️</div>
        <p class="health-card-eyebrow">Sistem Pengelolaan Sampah</p>
        <h3 class="health-card-title">Pengelolaan Sampah Domestik</h3>

        <div class="pct-ring-wrap">
          <!-- SVG Ring Chart -->
          <svg class="pct-ring" viewBox="0 0 90 90" role="img" aria-label="82% rumah mengelola sampah dengan benar">
            <circle cx="45" cy="45" r="36" fill="none" stroke="#e0f2fe" stroke-width="9"/>
            <circle
              cx="45" cy="45" r="36" fill="none" stroke="#0284c7" stroke-width="9"
              stroke-dasharray="226.2" stroke-dashoffset="22.6"
              stroke-linecap="round"
              transform="rotate(-90 45 45)"
              style="transition: stroke-dashoffset 1.5s ease;"
            />
            <text x="45" y="50" text-anchor="middle" font-size="14" font-weight="800" fill="#0369a1">82%</text>
          </svg>
          <div class="pct-ring-text">
            <div class="pct-ring-value" style="color:#0284c7;">82%</div>
            <div class="pct-ring-desc">Rumah tangga mengelola sampah dengan cara dibakar, dibuang ke sungai, atau dikubur.</div>
          </div>
        </div>

        <!-- Pictogram houses -->
        <div class="pictogram-row" role="img" aria-label="9 dari 10 rumah memiliki sanitasi baik" style="margin-top:0.75rem;">
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item">🏠</span>
          <span class="pictogram-item" style="opacity:0.25;">🏚️</span>
        </div>
      </article>

      <!-- Card 3: Tindakan Medis (Flowchart) -->
      <article
        class="health-card reveal reveal-delay-3"
        id="card-medis"
        style="--card-accent: linear-gradient(90deg, #a0622a, #d4975a);"
      >
        <div class="health-card-icon" style="--icon-bg: #f5e6d0;" aria-hidden="true">🏥</div>
        <p class="health-card-eyebrow">Tindakan Medis</p>
        <h3 class="health-card-title">Ke Mana Warga Saat Sakit?</h3>

        <div class="flow-chart" role="img" aria-label="Alur tindakan medis warga">
          <div class="flow-start">😷 Warga Merasa Sakit</div>
          <div class="flow-arrow">↓</div>
          <div class="flow-branches">
            <div class="flow-node flow-node-primary">
              <span class="node-icon">🏥</span>
              Ke Puskesmas / Klinik
              <span class="flow-pct">62%</span>
            </div>
            <div class="flow-node flow-node-secondary">
              <span class="node-icon">💊</span>
              Obat Mandiri / Warung
              <span class="flow-pct">38%</span>
            </div>
          </div>
          <div class="flow-arrow" style="font-size:0.75rem;color:var(--clr-emerald-600);font-weight:700;margin-top:0.5rem;">
            ✅ Target: Tingkatkan kunjungan ke fasilitas kesehatan
          </div>
        </div>
      </article>

      <!-- Card 4: Posyandu / KIA -->
      <article
        class="health-card reveal reveal-delay-4"
        id="card-posyandu"
        style="--card-accent: linear-gradient(90deg, #7c3aed, #a78bfa);"
      >
        <div class="health-card-icon" style="--icon-bg: #ede9fe;" aria-hidden="true">👶</div>
        <p class="health-card-eyebrow">Posyandu &amp; KIA</p>
        <h3 class="health-card-title">Kesehatan Ibu dan Anak (KIA)</h3>

        <div class="kia-highlight">
          <div class="kia-big-num" aria-hidden="true">100%</div>
          <div class="kia-text">
            <strong>Seluruh Anak di Atas Garis Merah</strong>
            <span>Tidak ada balita yang berada di bawah atau di garis merah KIA / KMS</span>
          </div>
        </div>

        <div class="kia-children-row" role="img" aria-label="Semua balita sehat">
          <span class="pictogram-item">👶</span>
          <span class="pictogram-item">👧</span>
          <span class="pictogram-item">👦</span>
          <span class="pictogram-item">👶</span>
          <span class="pictogram-item">👧</span>
          <span class="pictogram-item">👦</span>
          <span class="pictogram-item">👶</span>
          <span class="pictogram-item">👧</span>
        </div>
        <p style="font-size:0.8rem;color:var(--clr-gray-500);margin-top:0.5rem;">
          🛡️ <strong style="color:var(--clr-emerald-700);">Zero Stunting</strong> – Prestasi Luar Biasa Kelurahan!
        </p>

        <!-- Progress bar for posyandu attendance -->
        <div style="margin-top:0.75rem;">
          <div style="display:flex;justify-content:space-between;font-size:0.75rem;color:var(--clr-gray-400);margin-bottom:0.35rem;">
            <span>Kehadiran Posyandu Rutin</span><span>95%</span>
          </div>
          <div class="rw-progress-bar">
            <div class="rw-progress-fill" data-width="95%" style="background: linear-gradient(90deg, #7c3aed, #a78bfa);"></div>
          </div>
        </div>
      </article>

    </div>
  </div>
</section>

<!-- Wave Divider -->
<div class="wave-divider" aria-hidden="true" style="background:white;">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,30 C360,0 720,60 1080,30 C1260,15 1380,45 1440,30 L1440,60 L0,60 Z" fill="var(--clr-mist)"/>
  </svg>
</div>

<script>
  /* ---------- Scroll Reveal ---------- */
  const revealEls = document.querySelectorAll('.reveal');

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

  revealEls.forEach(el => revealObserver.observe(el));

  /* ---------- Progress Bar Animation ---------- */
  const progressFills = document.querySelectorAll('.rw-progress-fill');

  const progressObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const fill = entry.target as HTMLElement;
        const targetWidth = fill.getAttribute('data-width');
        if (targetWidth) {
          setTimeout(() => { fill.style.width = targetWidth; }, 200);
        }
        progressObserver.unobserve(fill);
      }
    });
  }, { threshold: 0.5 });

  progressFills.forEach(fill => progressObserver.observe(fill));
</script>

<style>
  /* ===== Live Survey Stats Widget ===== */
  .live-survey-wrap {
    background: #fff;
    border-radius: 1.25rem;
    border: 1px solid rgba(5,150,105,.15);
    box-shadow: 0 4px 24px rgba(5,150,105,.08);
    overflow: hidden;
    margin-bottom: 2.5rem;
  }
  .live-survey-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .75rem 1.25rem;
    background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
    border-bottom: 1px solid rgba(5,150,105,.12);
    flex-wrap: wrap;
    gap: .5rem;
  }
  .live-survey-title {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .85rem;
    color: #111827;
  }
  .live-survey-sub {
    font-size: .72rem;
    color: #6b7280;
    font-weight: 400;
  }
  .live-dot {
    width: 8px; height: 8px;
    background: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(16,185,129,.25);
    animation: livePulse 1.8s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes livePulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(16,185,129,.25); }
    50%       { box-shadow: 0 0 0 6px rgba(16,185,129,.08); }
  }
  .live-survey-status {
    font-size: .7rem;
    font-weight: 700;
    color: #6b7280;
    background: #f3f4f6;
    padding: .2rem .6rem;
    border-radius: .4rem;
    border: 1px solid #e5e7eb;
  }
  .live-survey-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0;
  }
  .kes-stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.1rem .75rem;
    border-right: 1px solid #f0f0f0;
    text-align: center;
    transition: background .2s;
  }
  .kes-stat-card:last-child { border-right: none; }
  .kes-stat-card:hover { background: #f9fafb; }
  .kes-stat-icon { font-size: 1.4rem; margin-bottom: .25rem; }
  .kes-stat-val {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: -.03em;
    line-height: 1.1;
  }
  .kes-stat-lbl {
    font-size: .62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: #9ca3af;
    margin: .2rem 0 .3rem;
  }
  .kes-stat-badge {
    font-size: .6rem;
    font-weight: 700;
    padding: .15rem .4rem;
    border-radius: .25rem;
  }
  .ks-green  { background: #d1fae5; color: #065f46; }
  .ks-red    { background: #fee2e2; color: #991b1b; }
  .ks-yellow { background: #fef3c7; color: #92400e; }
  .ks-blue   { background: #dbeafe; color: #1e40af; }

  /* Skeleton */
  .kes-stat-skeleton {
    height: 90px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.4s ease-in-out infinite;
  }
  @keyframes skeletonShimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (max-width: 600px) {
    .live-survey-grid { grid-template-columns: repeat(2, 1fr); }
    .kes-stat-card:nth-child(even) { border-right: none; }
    .kes-stat-card { border-bottom: 1px solid #f0f0f0; }
  }
</style>

<script>
/* ── Live Stats Widget: Kesehatan Section ── */
(function () {
  const API_URL = 'https://script.googleusercontent.com/macros/echo?user_content_key=AUkAhnTCV_rOINifo-eMc4SrWQ4ihhSv8as4Zolw8_dv-S9tFT1Xbz5g4r7Pp0h0YDIGDLiJBxUNnj6V1dFFpDjXgDKvpOR56WUBYIf--6blufGgCUeyAXkVs80vjtEPPGgBxebHY0_6bgKGhWVEr4LFAxcX0igCDzl0O7_xs-2QaA6yRpGT3bixoH1sI5Nt9xHlPopxhA76fHeoljx2cMpvknGNea21r5yZA5CwLo3mvX8LYrOnvjapqZJJdmPviYToU9b34RiUPpiDKOcDbfk_0EWbEGJAVQ&lib=MDLAdFgRGOJVJ01oTM4DbJHdi3ZE4dG0b';

  function renderKesStats(rawData: any[]): void {
    const grid   = document.getElementById('kes-stats-grid');
    const status = document.getElementById('kes-api-status');
    if (!grid) return;

    // Agregasi
    let totalKK = 0, totalJiwa = 0, jamban = 0, nyeri = 0, dokter = 0, obat = 0;
    rawData.forEach((kk: any) => {
      totalKK++;
      totalJiwa += Number(kk.anggota_keluarga) || 0;
      if (kk.kondisi_jamban === 'Baik/Layak')               jamban++;
      if (kk.keluhan_nyeri_gigi === 'Ya')                   nyeri++;
      if (kk.tindakan_medis_gigi === 'Pernah ke Dokter Gigi') dokter++;
      if (kk.tindakan_medis_gigi === 'Membeli Obat Saja')   obat++;
    });

    const pSanitasi = totalKK ? Math.round(jamban  / totalKK * 100) : 0;
    const pNyeri    = totalKK ? Math.round(nyeri   / totalKK * 100) : 0;
    const pDokter   = totalKK ? Math.round(dokter  / totalKK * 100) : 0;
    const pObat     = totalKK ? Math.round(obat    / totalKK * 100) : 0;

    if (status) status.innerHTML = `🟢 Live · ${totalKK} KK`;

    grid.innerHTML = `
      <div class="kes-stat-card">
        <div class="kes-stat-icon">🏠</div>
        <div class="kes-stat-val" style="color:#059669">${totalKK}</div>
        <div class="kes-stat-lbl">KK Tersurvei</div>
        <span class="kes-stat-badge ks-green">Data Lapangan</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">👥</div>
        <div class="kes-stat-val" style="color:#1d4ed8">${totalJiwa}</div>
        <div class="kes-stat-lbl">Jiwa Terdata</div>
        <span class="kes-stat-badge ks-blue">Akumulatif</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">💧</div>
        <div class="kes-stat-val" style="color:${pSanitasi >= 90 ? '#059669' : '#f97316'}">${pSanitasi}%</div>
        <div class="kes-stat-lbl">Sanitasi Layak</div>
        <span class="kes-stat-badge ${pSanitasi >= 90 ? 'ks-green' : 'ks-yellow'}">${pSanitasi >= 90 ? '✅ Sangat Baik' : '⚠️ Perlu Perhatian'}</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">🦷</div>
        <div class="kes-stat-val" style="color:#dc2626">${pNyeri}%</div>
        <div class="kes-stat-lbl">Keluhan Nyeri Gigi</div>
        <span class="kes-stat-badge ks-red">⚠️ Ironi Klinis</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">🏥</div>
        <div class="kes-stat-val" style="color:${pDokter >= 30 ? '#059669' : '#dc2626'}">${pDokter}%</div>
        <div class="kes-stat-lbl">Akses ke Dokter</div>
        <span class="kes-stat-badge ${pDokter >= 30 ? 'ks-green' : 'ks-red'}">${pDokter >= 30 ? '✅ Cukup' : '🆘 Kritis'}</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">💊</div>
        <div class="kes-stat-val" style="color:#f97316">${pObat}%</div>
        <div class="kes-stat-lbl">Obat Warung</div>
        <span class="kes-stat-badge ks-yellow">💊 Swamedikasi</span>
      </div>
    `;
  }

  fetch(API_URL)
    .then(r => r.json())
    .then((payload: any) => {
      const raw = Array.isArray(payload) ? payload : (payload.survei ?? []);
      renderKesStats(raw);
    })
    .catch(() => {
      const status = document.getElementById('kes-api-status');
      const grid   = document.getElementById('kes-stats-grid');
      if (status) status.innerHTML = '🟡 Offline';
      if (grid)   grid.innerHTML = '<p style="padding:1rem;color:#9ca3af;font-size:.8rem;text-align:center;">Data tidak tersedia saat ini.</p>';
    });
})();
</script>
