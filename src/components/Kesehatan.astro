<script>
/* ---------- Scroll Reveal & Animations ---------- */
document.addEventListener("DOMContentLoaded", () => {

  // Fade/Slide Reveal
  const revealEls = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  revealEls.forEach(el => revealObserver.observe(el));

  // Progress Bar Animation
  const progressFills = document.querySelectorAll('.rw-progress-fill');
  const progressObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const fill = entry.target as HTMLElement;
        const targetWidth = fill.getAttribute('data-width');
        if (targetWidth) setTimeout(() => { fill.style.width = targetWidth; }, 300);
        progressObserver.unobserve(fill);
      }
    });
  }, { threshold: 0.5 });
  progressFills.forEach(fill => progressObserver.observe(fill));

  // SVG Ring Animation
  const rings = document.querySelectorAll('.ring-animate');
  const ringObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const ring = entry.target as SVGElement;
        const targetOffset = ring.getAttribute('data-offset');
        if (targetOffset) setTimeout(() => { (ring as any).style.strokeDashoffset = targetOffset; }, 400);
        ringObserver.unobserve(ring);
      }
    });
  }, { threshold: 0.5 });
  rings.forEach(ring => ringObserver.observe(ring));

});

/* ---------- Live API Fetch (Unified) ---------- */
(function () {
  const API_URL = 'https://script.googleusercontent.com/macros/echo?user_content_key=AUkAhnQjZyOnFpb-cxOFHqzjoPq_m6f733zhOBiy5EW-5XySDs5NMUo4sSXUTgiDdUPyeP6doL9xmREJvuTJ4mD5AVpDqwIq94KT71syJchqgXv45vhYO_LJ3K55uW91vyV5Q5-Okzng24UyXDz-IZcc82WMgVq91t5EXTBepv1bjvlV2jg4Lc3iaTbTAzbbjXFB688ysePGnE8-ncAHUq8ZdqBV8sKiyMqDvFzMP05fIJXsaq9B_XpdTBNknCCMj1_DNoIXBrfO3vRaM7bA79XoW-8Ia08b3A&lib=MDLAdFgRGOJVJ01oTM4DbJHdi3ZE4dG0b';

  const LOCAL_IMAGES: Record<string, string> = {
    '1zgN7jYjf4TlX87decR1sNdKAifaDSqA9': '/images/galeri/posyandu_kader.jpg',
    '12X6-h_FEgGQx5P4IlCv2c2lLrQm5NsyR': '/images/galeri/posyandu_anak.jpg',
    '1KqHvoTxVBG1g8Zb0nocjCfzOMSvBZP3r': '/images/galeri/modul_toga.jpg',
    '1rnnOkHVtnBn6teA1aXELsdU9FIKANSSW': '/images/galeri/olahraga.jpg',
    '11-uWFl8J9eXZzAaQureuND2c1Ypqpg69': '/images/galeri/gotong_royong.jpg',
  };

  /* -- Helpers -- */
  function driveUrl(raw: string): string {
    if (!raw) return '';
    let fileId = '';
    const ucMatch = raw.match(/[?&]id=([^&]+)/);
    if (ucMatch) fileId = ucMatch[1];
    if (!fileId) {
      const fileMatch = raw.match(/\/d\/([^/?]+)/);
      if (fileMatch) fileId = fileMatch[1];
    }
    if (fileId) {
      // Menggunakan file lokal jika tersedia agar terhindar dari rate limit Google Drive
      if (LOCAL_IMAGES[fileId]) {
        return LOCAL_IMAGES[fileId];
      }
      return `https://lh3.googleusercontent.com/d/${fileId}`;
    }
    return raw;
  }

  function formatDate(iso: string): string {
    try {
      return new Date(iso).toLocaleDateString('id-ID', {
        day: 'numeric', month: 'long', year: 'numeric'
      });
    } catch { return iso; }
  }

  /* -- Render: Live Survey Stats -- */
  function renderKesStats(rawData: any[]): void {
    const grid   = document.getElementById('kes-stats-grid');
    const status = document.getElementById('kes-api-status');
    if (!grid) return;

    let totalKK = 0, totalJiwa = 0, jamban = 0, nyeri = 0, dokter = 0, rentan = 0;
    rawData.forEach((kk: any) => {
      totalKK++;
      totalJiwa += Number(kk.anggota_keluarga) || 0;
      if (kk.kondisi_jamban === 'Baik/Layak')                    jamban++;
      if (kk.keluhan_nyeri_gigi === 'Ya')                        nyeri++;
      if (kk.tindakan_medis_gigi === 'Pernah ke Dokter Gigi')    dokter++;
      if (kk.kelompok_rentan && kk.kelompok_rentan !== 'Tidak Ada') rentan++;
    });

    const pSanitasi = totalKK ? Math.round(jamban  / totalKK * 100) : 0;
    const pNyeri    = totalKK ? Math.round(nyeri   / totalKK * 100) : 0;
    const pDokter   = totalKK ? Math.round(dokter  / totalKK * 100) : 0;

    if (status) status.innerHTML = `🟢 Live · ${totalKK} KK Terdata`;

    grid.innerHTML = `
      <div class="kes-stat-card">
        <div class="kes-stat-icon">🏠</div>
        <div class="kes-stat-val" style="color:#059669">${totalKK}</div>
        <div class="kes-stat-lbl">KK Tersurvei</div>
        <span class="kes-stat-badge ks-green">Data Lapangan</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">👥</div>
        <div class="kes-stat-val" style="color:#1d4ed8">${totalJiwa}</div>
        <div class="kes-stat-lbl">Jiwa Terdata</div>
        <span class="kes-stat-badge ks-blue">Akumulatif</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">💧</div>
        <div class="kes-stat-val" style="color:${pSanitasi >= 90 ? '#059669' : '#f97316'}">${pSanitasi}%</div>
        <div class="kes-stat-lbl">Sanitasi Layak</div>
        <span class="kes-stat-badge ${pSanitasi >= 90 ? 'ks-green' : 'ks-yellow'}">${pSanitasi >= 90 ? '✅ Sangat Baik' : '⚠️ Perlu Perhatian'}</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">🦷</div>
        <div class="kes-stat-val" style="color:#dc2626">${pNyeri}%</div>
        <div class="kes-stat-lbl">Keluhan Nyeri Gigi</div>
        <span class="kes-stat-badge ks-red">1 Bulan Terakhir</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">🏥</div>
        <div class="kes-stat-val" style="color:${pDokter >= 30 ? '#059669' : '#dc2626'}">${pDokter}%</div>
        <div class="kes-stat-lbl">Akses ke Dokter</div>
        <span class="kes-stat-badge ${pDokter >= 30 ? 'ks-green' : 'ks-red'}">${pDokter >= 30 ? '✅ Cukup' : '🆘 Kritis'}</span>
      </div>
      <div class="kes-stat-card">
        <div class="kes-stat-icon">⚠️</div>
        <div class="kes-stat-val" style="color:#7c3aed">${rentan}</div>
        <div class="kes-stat-lbl">Kelompok Rentan</div>
        <span class="kes-stat-badge ks-purple">Balita & Lansia</span>
      </div>
    `;
  }

  /* -- Render: Prevalensi Balita per RW -- */
  function renderPrevalensi(data: any[]): void {
    const grid = document.getElementById('prevalensi-grid');
    if (!grid || !data.length) {
      if (grid) grid.innerHTML = '<p style="color:#9ca3af;font-size:0.85rem;grid-column:1/-1;">Data prevalensi belum tersedia.</p>';
      return;
    }

    const maxKaries  = Math.max(...data.map((d: any) => d.persen_karies  || 0));
    const maxStunting = Math.max(...data.map((d: any) => d.persen_stunting || 0));

    grid.innerHTML = data.map((d: any) => {
      const pKaries   = Math.round((d.persen_karies  || 0) * 100);
      const pStunting = Math.round((d.persen_stunting || 0) * 100);
      const barK = maxKaries   ? Math.round((d.persen_karies  || 0) / maxKaries   * 100) : 0;
      const barS = maxStunting ? Math.round((d.persen_stunting || 0) / maxStunting * 100) : 0;
      return `
        <div class="prev-card">
          <div class="prev-card-header">
            <span class="prev-rw">${d.rw}</span>
            <span class="prev-total">${d.total_balita} balita</span>
          </div>
          <div class="prev-bar-wrap">
            <div class="prev-bar-label">
              <span>🦷 Karies</span><strong style="color:#dc2626">${pKaries}%</strong>
            </div>
            <div class="prev-bar-track">
              <div class="prev-bar-fill prev-bar-karies" style="width:0%" data-w="${barK}%"></div>
            </div>
          </div>
          <div class="prev-bar-wrap">
            <div class="prev-bar-label">
              <span>📉 Stunting</span><strong style="color:#f97316">${pStunting}%</strong>
            </div>
            <div class="prev-bar-track">
              <div class="prev-bar-fill prev-bar-stunting" style="width:0%" data-w="${barS}%"></div>
            </div>
          </div>
          <div class="prev-card-footer">
            Karies: ${d.karies ?? 0} anak · Stunting: ${d.stunting ?? 0} anak
          </div>
        </div>
      `;
    }).join('');

    // Animate bars on intersection
    const bars = grid.querySelectorAll('.prev-bar-fill');
    const barObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          setTimeout(() => { el.style.width = el.dataset.w || '0%'; }, 400);
          barObserver.unobserve(el);
        }
      });
    }, { threshold: 0.3 });
    bars.forEach(b => barObserver.observe(b));
  }

  /* -- Render: Galeri Kegiatan -- */
  let allGaleri: any[] = [];
  let currentItems: any[] = [];

  function renderGaleri(data: any[]): void {
    allGaleri = data;
    renderGaleriFiltered('all');

    document.querySelectorAll('.gtab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.gtab').forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        renderGaleriFiltered((btn as HTMLElement).dataset.filter || 'all');
      });
    });
  }

  function renderGaleriFiltered(filter: string): void {
    const grid  = document.getElementById('galeri-grid');
    const empty = document.getElementById('galeri-empty') as HTMLElement | null;
    if (!grid) return;

    currentItems = filter === 'all' ? allGaleri : allGaleri.filter((g: any) => g.tipe === filter);

    if (!currentItems.length) {
      grid.innerHTML = '';
      if (empty) empty.hidden = false;
      return;
    }
    if (empty) empty.hidden = true;

    const rwPad = (rw: number) => rw < 10 ? '0' + rw : '' + rw;

    grid.innerHTML = currentItems.map((g: any, i: number) => `
      <div class="galeri-card" data-idx="${i}" role="button" tabindex="0" aria-label="Lihat foto: ${g.keterangan}">
        <div class="galeri-thumb">
          <img
            src="${driveUrl(g.url_foto)}"
            alt="${g.keterangan}"
            loading="lazy"
            onerror="this.parentElement.innerHTML='<div class=\\'galeri-img-err\\'>📷</div>'"
          />
          <span class="galeri-tipe-badge ${g.tipe === 'DS' ? 'badge-ds' : 'badge-toga'}">${g.tipe === 'DS' ? '🏥 Desa Sehat' : '🌿 TOGA'}</span>
        </div>
        <div class="galeri-info">
          <p class="galeri-kegiatan">${g.kegiatan || '-'}</p>
          <p class="galeri-ket">${g.keterangan || ''}</p>
          <div class="galeri-meta">
            <span class="galeri-rw-badge">RW ${rwPad(g.rw)}</span>
            <span class="galeri-date">${formatDate(g.tanggal)}</span>
          </div>
        </div>
      </div>
    `).join('');

    grid.querySelectorAll('.galeri-card').forEach(card => {
      const open = () => openLightbox(Number((card as HTMLElement).dataset.idx));
      card.addEventListener('click', open);
      card.addEventListener('keydown', (e: Event) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') open();
      });
    });
  }

  /* -- Render: Update Detailed Health Cards -- */
  function updateDetailedHealthCards(survei: any[], prevalensi: any[]): void {
    if (!survei || !survei.length) return;

    let totalKK = 0;
    let sikatGigi2x = 0;
    let jambanLayak = 0;
    let sampahTps = 0;
    let medisDokter = 0;
    let medisObat = 0;

    survei.forEach((kk: any) => {
      totalKK++;
      if (kk.perilaku_sikat_gigi === '2x Sehari') {
        sikatGigi2x++;
      }
      if (kk.kondisi_jamban === 'Baik/Layak') {
        jambanLayak++;
      }
      if (kk.pengelolaan_sampah === 'Dibuang ke TPS') {
        sampahTps++;
      }
      if (kk.tindakan_medis_gigi === 'Pernah ke Dokter Gigi') {
        medisDokter++;
      } else if (kk.tindakan_medis_gigi === 'Membeli Obat Saja') {
        medisObat++;
      }
    });

    const pSikat = totalKK ? Math.round((sikatGigi2x / totalKK) * 100) : 80;
    const pSani  = totalKK ? Math.round((jambanLayak / totalKK) * 100) : 90;
    const pSampah = totalKK ? Math.round((sampahTps / totalKK) * 100) : 82;

    const totalMedisGigi = medisDokter + medisObat;
    const pMedisDokter = totalMedisGigi ? Math.round((medisDokter / totalMedisGigi) * 100) : 62;
    const pMedisObat   = totalMedisGigi ? Math.round((medisObat / totalMedisGigi) * 100) : 38;

    // --- Card 1: Gigi & Mulut ---
    const gigiPicRow = document.getElementById('gigi-pic-row');
    const gigiPicLabel = document.getElementById('gigi-pic-label');
    const gigiPctText = document.getElementById('gigi-pct-text');
    const gigiProgressFill = document.getElementById('gigi-progress-fill') as HTMLElement | null;

    const activeSmileyCount = Math.round((pSikat / 100) * 10);
    if (gigiPicRow) {
      gigiPicRow.setAttribute('aria-label', `${activeSmileyCount} dari 10 warga sudah sikat gigi 2 kali sehari`);
      gigiPicRow.innerHTML = Array.from({ length: 10 }).map((_, i) => {
        if (i < activeSmileyCount) {
          return '<span class="pictogram-item" title="Sikat gigi rutin">😁</span>';
        } else {
          return '<span class="pictogram-item" style="opacity:0.25;" title="Belum rutin">😶</span>';
        }
      }).join('');
    }
    if (gigiPicLabel) {
      gigiPicLabel.innerHTML = `<strong>${activeSmileyCount} dari 10</strong> warga sudah sikat gigi 2× sehari (pagi &amp; malam).`;
    }
    if (gigiPctText) {
      gigiPctText.textContent = `${pSikat}%`;
    }
    if (gigiProgressFill) {
      gigiProgressFill.setAttribute('data-width', `${pSikat}%`);
      gigiProgressFill.style.width = `${pSikat}%`;
    }

    // --- Card 2: Sanitasi ---
    const saniRingFill = document.getElementById('sanitasi-ring-fill') as any;
    const saniPctVal = document.getElementById('sanitasi-pct-val');
    const saniPicRow = document.getElementById('sanitasi-pic-row');

    if (saniRingFill) {
      const circ = 226.2;
      const offset = circ - (circ * pSani) / 100;
      saniRingFill.setAttribute('stroke-dashoffset', String(offset));
      saniRingFill.setAttribute('data-offset', String(offset));
    }
    if (saniPctVal) {
      saniPctVal.textContent = `${pSani}%`;
    }
    const activeHouseCount = Math.round((pSani / 100) * 10);
    if (saniPicRow) {
      saniPicRow.setAttribute('aria-label', `${activeHouseCount} dari 10 rumah memiliki jamban sehat`);
      saniPicRow.innerHTML = Array.from({ length: 10 }).map((_, i) => {
        if (i < activeHouseCount) {
          return '<span class="pictogram-item">🏠</span>';
        } else {
          return '<span class="pictogram-item" style="opacity:0.25;">🏚️</span>';
        }
      }).join('');
    }

    // --- Card 3: Sampah ---
    const sampahRingFill = document.getElementById('sampah-ring-fill') as any;
    const sampahPctVal = document.getElementById('sampah-pct-val');
    const sampahPicRow = document.getElementById('sampah-pic-row');

    if (sampahRingFill) {
      const circ = 226.2;
      const offset = circ - (circ * pSampah) / 100;
      sampahRingFill.setAttribute('stroke-dashoffset', String(offset));
      sampahRingFill.setAttribute('data-offset', String(offset));
    }
    if (sampahPctVal) {
      sampahPctVal.textContent = `${pSampah}%`;
    }
    const activeTrashCount = Math.round((pSampah / 100) * 10);
    if (sampahPicRow) {
      sampahPicRow.setAttribute('aria-label', `${activeTrashCount} dari 10 rumah mengelola sampah dengan benar`);
      sampahPicRow.innerHTML = Array.from({ length: 10 }).map((_, i) => {
        if (i < activeTrashCount) {
          return '<span class="pictogram-item">🗑️</span>';
        } else {
          return '<span class="pictogram-item" style="opacity:0.25;">🗑️</span>';
        }
      }).join('');
    }

    // --- Card 4: Tindakan Medis ---
    const medisPctPuskesmas = document.getElementById('medis-pct-puskesmas');
    const medisPctWarung = document.getElementById('medis-pct-warung');

    if (medisPctPuskesmas) {
      medisPctPuskesmas.textContent = `${pMedisDokter}%`;
    }
    if (medisPctWarung) {
      medisPctWarung.textContent = `${pMedisObat}%`;
    }

    // --- Card 5: Posyandu / KIA ---
    if (prevalensi && prevalensi.length) {
      let totalBalita = 0;
      let totalStunting = 0;
      prevalensi.forEach((d: any) => {
        totalBalita += Number(d.total_balita) || 0;
        totalStunting += Number(d.stunting) || 0;
      });

      const pBebasStunting = totalBalita ? Math.round(((totalBalita - totalStunting) / totalBalita) * 100) : 100;

      const kiaPctVal = document.getElementById('kia-pct-val');
      const kiaTextDesc = document.getElementById('kia-text-desc');
      const kiaChildrenRow = document.getElementById('kia-children-row');
      const kiaStuntingBadge = document.getElementById('kia-stunting-badge');

      if (kiaPctVal) {
        kiaPctVal.textContent = `${pBebasStunting}%`;
      }
      if (kiaTextDesc) {
        kiaTextDesc.innerHTML = `
          <strong>Balita Tumbuh Optimal</strong>
          <span>Sebanyak ${totalBalita - totalStunting} dari ${totalBalita} balita di seluruh RW tumbuh optimal &amp; bebas stunting.</span>
        `;
      }
      if (kiaChildrenRow) {
        kiaChildrenRow.setAttribute('aria-label', `Prevalensi balita tumbuh optimal ${pBebasStunting}%`);
        const optimalChildEmojis = Math.round((pBebasStunting / 100) * 8);
        const childEmojis = ['👶', '👧', '👦'];
        kiaChildrenRow.innerHTML = Array.from({ length: 8 }).map((_, i) => {
          const emoji = childEmojis[i % childEmojis.length];
          if (i < optimalChildEmojis) {
            return `<span class="pictogram-item">${emoji}</span>`;
          } else {
            return `<span class="pictogram-item" style="opacity:0.25;" title="Kondisi Kurang Optimal">${emoji}</span>`;
          }
        }).join('');
      }
      if (kiaStuntingBadge) {
        if (totalStunting === 0) {
          kiaStuntingBadge.innerHTML = `🛡️ <strong>Zero Stunting</strong> – Indikator kesehatan balita di kelurahan sangat optimal!`;
        } else {
          kiaStuntingBadge.innerHTML = `🛡️ <strong>Optimalisasi Tumbuh Kembang</strong> – Terus tingkatkan asupan nutrisi &amp; kunjungan Posyandu!`;
        }
      }
    }
  }

  /* -- Lightbox -- */
  function openLightbox(idx: number): void {
    const g   = currentItems[idx];
    if (!g) return;
    const lb  = document.getElementById('kes-lightbox');
    const img = document.getElementById('kes-lb-img') as HTMLImageElement | null;
    const cap = document.getElementById('kes-lb-cap');
    if (!lb || !img || !cap) return;

    img.src = driveUrl(g.url_foto);
    img.alt = g.keterangan || '';
    const rwPad = (rw: number) => rw < 10 ? '0' + rw : '' + rw;
    cap.innerHTML = `
      <strong>${g.kegiatan || ''}</strong>
      <span>${g.keterangan || ''}</span>
      <span class="lb-rw">RW ${rwPad(g.rw)} · ${formatDate(g.tanggal)}</span>
    `;
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox(): void {
    const lb = document.getElementById('kes-lightbox');
    if (lb) lb.hidden = true;
    document.body.style.overflow = '';
  }

  document.getElementById('kes-lb-close')?.addEventListener('click', closeLightbox);
  document.getElementById('kes-lb-backdrop')?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeLightbox(); });

  /* -- Main Fetch -- */
  function loadKesehatanData(url: string, isFallback: boolean = false): void {
    const status = document.getElementById('kes-api-status');
    fetch(url)
      .then(r => {
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        return r.json();
      })
      .then((payload: any) => {
        const survei     = Array.isArray(payload) ? payload : (payload.survei     ?? []);
        const prevalensi = payload.prevalensi ?? [];
        const galeri     = payload.galeri     ?? [];

        renderKesStats(survei);
        renderPrevalensi(prevalensi);
        updateDetailedHealthCards(survei, prevalensi);
        renderGaleri(galeri);

        if (status) {
          status.innerHTML = isFallback ? '🟢 Live · Local Mode' : `🟢 Live · ${survei.length} KK Terdata`;
        }
      })
      .catch((err) => {
        console.warn(`Fetch gagal untuk ${url}:`, err);
        if (!isFallback) {
          if (status) status.innerHTML = '⏳ Menghubungkan ke Lokal...';
          // Silent fallback ke data local yang sudah kita siapkan
          loadKesehatanData('/data-kesehatan-fallback.json', true);
        } else {
          if (status) status.innerHTML = '🟡 Offline';
          const grid = document.getElementById('kes-stats-grid');
          if (grid) grid.innerHTML = '<p style="padding:1.5rem;color:#9ca3af;font-size:0.9rem;text-align:center;grid-column:1/-1;">Data tidak tersedia saat ini.</p>';
        }
      });
  }

  loadKesehatanData(API_URL);

})();
</script>