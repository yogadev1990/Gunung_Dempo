---
// Kesehatan.astro
---

<section class="section section-sehat" id="sehat" aria-labelledby="sehat-title">
  <div class="container">

    <header class="section-header">
      <span class="eyebrow reveal">🏥 Desa Sehat</span>
      <h2 class="section-title reveal" id="sehat-title">
        Data <span>Kesehatan</span> Masyarakat
      </h2>
      <p class="section-desc reveal">
        Hasil survei dan edukasi warga 1-on-1 oleh Tim KKNT 103 Kelompok 25 Universitas Sriwijaya untuk masyarakat Kelurahan Gunung Dempo. Data dapat digunakan untuk membantu meningkatkan kesehatan warga.
      </p>
    </header>

    <!-- ===== LIVE DATA SURVEI LAPANGAN ===== -->
    <div class="live-survey-wrap reveal">
      <div class="live-survey-header">
        <div class="live-survey-title">
          <span class="live-dot" aria-hidden="true"></span>
          <strong>Data Survei Real-Time</strong>
          <span class="live-survey-sub">Door-to-Door & Posyandu · KKNT 103 Kelompok 25</span>
        </div>
        <span class="live-survey-status" id="kes-api-status">⏳ Menghubungkan…</span>
      </div>
      <div class="live-survey-grid" id="kes-stats-grid">
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
        <div class="kes-stat-skeleton"></div>
      </div>
    </div>

    <!-- ===== PREVALENSI BALITA (NEW) ===== -->
    <div class="prevalensi-wrap reveal">
      <div class="sub-section-header">
        <div class="sub-section-text">
          <span class="sub-eyebrow">📊 Data Balita Per RW</span>
          <h3 class="sub-title">Prevalensi Karies &amp; Stunting</h3>
        </div>
        <p class="sub-note">Sumber: Pendataan Posyandu · KKNT 103 Kelompok 25</p>
      </div>
      <div id="prevalensi-grid" class="prevalensi-grid">
        <div class="prev-skeleton"></div>
        <div class="prev-skeleton"></div>
        <div class="prev-skeleton"></div>
      </div>
    </div>

    <!-- ===== GRID KARTU KESEHATAN ===== -->
    <div class="health-grid">

      <!-- Card 1: Kesehatan Gigi & Mulut -->
      <article
        class="health-card reveal reveal-delay-1"
        id="card-gigi"
        style="--card-accent: linear-gradient(90deg, #059669, #34d399);"
      >
        <div class="health-card-icon" style="--icon-bg: #d1fae5;" aria-hidden="true">🦷</div>
        <p class="health-card-eyebrow">Kesehatan Gigi &amp; Mulut</p>
        <h3 class="health-card-title">Kebiasaan Sikat Gigi Warga</h3>

        <div class="pictogram-row" role="img" id="gigi-pic-row" aria-label="Kebiasaan sikat gigi warga">
          <!-- Dimuat dinamis via JS -->
          <div class="kes-shimmer-text" style="width: 100%; height: 1.5rem;"></div>
        </div>

        <p class="pictogram-label" id="gigi-pic-label">
          <span class="kes-shimmer-text kes-shimmer-long"></span>
        </p>

        <div class="progress-wrap">
          <div class="progress-label">
            <span>Rutin Sikat Gigi</span><span id="gigi-pct-text"><span class="kes-shimmer-text"></span></span>
          </div>
          <div class="rw-progress-bar">
            <div class="rw-progress-fill" id="gigi-progress-fill" data-width="0%" style="width: 0%;"></div>
          </div>
        </div>
      </article>

      <!-- Card 2: Sanitasi -->
      <article
        class="health-card reveal reveal-delay-2"
        id="card-sanitasi"
        style="--card-accent: linear-gradient(90deg, #0284c7, #38bdf8);"
      >
        <div class="health-card-icon" style="--icon-bg: #e0f2fe;" aria-hidden="true">🚿</div>
        <p class="health-card-eyebrow">Sanitasi &amp; Lingkungan</p>
        <h3 class="health-card-title">Fasilitas Jamban &amp; Air</h3>

        <div class="pct-ring-wrap">
          <svg class="pct-ring" viewBox="0 0 90 90" role="img" aria-label="Persentase jamban sehat">
            <circle cx="45" cy="45" r="36" fill="none" stroke="#e0f2fe" stroke-width="9"/>
            <circle
              cx="45" cy="45" r="36" fill="none" stroke="#0284c7" stroke-width="9"
              stroke-dasharray="226.2" stroke-dashoffset="226.2"
              stroke-linecap="round"
              transform="rotate(-90 45 45)"
              class="ring-animate" data-offset="226.2"
              id="sanitasi-ring-fill"
            />
          </svg>
          <div class="pct-ring-text">
            <div class="pct-ring-value" style="color:#0284c7;" id="sanitasi-pct-val"><span class="kes-shimmer-text"></span></div>
            <div class="pct-ring-desc" id="sanitasi-pct-desc">Rumah tangga memiliki jamban sehat.</div>
          </div>
        </div>

        <div class="pictogram-row" id="sanitasi-pic-row" role="img" aria-label="Pictogram sanitasi" style="margin-top:0.75rem;">
          <div class="kes-shimmer-text" style="width: 100%; height: 1.5rem;"></div>
        </div>
      </article>

      <!-- Card 3: Sampah -->
      <article
        class="health-card reveal reveal-delay-2"
        id="card-sampah"
        style="--card-accent: linear-gradient(90deg, #10b981, #34d399);"
      >
        <div class="health-card-icon" style="--icon-bg: #d1fae5;" aria-hidden="true">🗑️</div>
        <p class="health-card-eyebrow">Sistem Pengelolaan Sampah</p>
        <h3 class="health-card-title">Pengelolaan Sampah Domestik</h3>

        <div class="pct-ring-wrap">
          <svg class="pct-ring" viewBox="0 0 90 90" role="img" aria-label="Persentase pengelolaan sampah">
            <circle cx="45" cy="45" r="36" fill="none" stroke="#d1fae5" stroke-width="9"/>
            <circle
              cx="45" cy="45" r="36" fill="none" stroke="#10b981" stroke-width="9"
              stroke-dasharray="226.2" stroke-dashoffset="226.2"
              stroke-linecap="round"
              transform="rotate(-90 45 45)"
              class="ring-animate" data-offset="226.2"
              id="sampah-ring-fill"
            />
          </svg>
          <div class="pct-ring-text">
            <div class="pct-ring-value" style="color:#10b981;" id="sampah-pct-val"><span class="kes-shimmer-text"></span></div>
            <div class="pct-ring-desc" id="sampah-pct-desc">Masyarakat sudah mampu memilah dan mengelola sampah.</div>
          </div>
        </div>

        <div class="pictogram-row" id="sampah-pic-row" role="img" aria-label="Pictogram sampah" style="margin-top:0.75rem;">
          <div class="kes-shimmer-text" style="width: 100%; height: 1.5rem;"></div>
        </div>
      </article>

      <!-- Card 4: Tindakan Medis (Flowchart) -->
      <article
        class="health-card reveal reveal-delay-3"
        id="card-medis"
        style="--card-accent: linear-gradient(90deg, #f59e0b, #fbbf24);"
      >
        <div class="health-card-icon" style="--icon-bg: #fef3c7;" aria-hidden="true">🏥</div>
        <p class="health-card-eyebrow">Tindakan Medis</p>
        <h3 class="health-card-title">Ke Mana Warga Saat Sakit?</h3>

        <div class="flow-chart" role="img" aria-label="Alur tindakan medis warga">
          <div class="flow-start">😷 Warga Merasa Sakit</div>
          <div class="flow-arrow">↓</div>
          <div class="flow-branches">
            <div class="flow-node flow-node-primary">
              <span class="node-icon">🏥</span>
              Ke Puskesmas / Klinik
              <span class="flow-pct" id="medis-pct-puskesmas"><span class="kes-shimmer-text" style="width: 40px;"></span></span>
            </div>
            <div class="flow-node flow-node-secondary">
              <span class="node-icon">💊</span>
              Obat Mandiri / Warung
              <span class="flow-pct" id="medis-pct-warung"><span class="kes-shimmer-text" style="width: 40px;"></span></span>
            </div>
          </div>
          <div class="flow-note">
            ✅ <strong>Target:</strong> Tingkatkan angka kunjungan medis ke fasilitas kesehatan yang layak.
          </div>
        </div>
      </article>

      <!-- Card 5: Posyandu / KIA -->
      <article
        class="health-card reveal reveal-delay-4"
        id="card-posyandu"
        style="--card-accent: linear-gradient(90deg, #8b5cf6, #a78bfa);"
      >
        <div class="health-card-icon" style="--icon-bg: #ede9fe;" aria-hidden="true">👶</div>
        <p class="health-card-eyebrow">Posyandu &amp; KIA</p>
        <h3 class="health-card-title">Kesehatan Ibu dan Anak (KIA)</h3>

        <div class="kia-highlight">
          <div class="kia-big-num" aria-hidden="true" id="kia-pct-val"><span class="kes-shimmer-text" style="width: 60px; height: 2rem;"></span></div>
          <div class="kia-text" id="kia-text-desc">
            <span class="kes-shimmer-text kes-shimmer-long"></span>
          </div>
        </div>

        <div class="kia-children-row" id="kia-children-row" role="img" aria-label="Tingkat tumbuh kembang anak">
          <div class="kes-shimmer-text" style="width: 100%; height: 1.5rem;"></div>
        </div>

        <p class="kia-badge" id="kia-stunting-badge">
          🛡️ <span class="kes-shimmer-text kes-shimmer-long" style="width: 180px;"></span>
        </p>
      </article>

    </div>
  </div>
</section>

<!-- Wave Divider -->
<div class="wave-divider" aria-hidden="true" style="background:white;">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,30 C360,0 720,60 1080,30 C1260,15 1380,45 1440,30 L1440,60 L0,60 Z" fill="#f8fafc"/>
  </svg>
</div>

<!-- Lightbox -->
<div id="kes-lightbox" class="kes-lightbox" role="dialog" aria-modal="true" aria-label="Pratinjau foto" hidden>
  <div class="kes-lb-backdrop" id="kes-lb-backdrop"></div>
  <div class="kes-lb-container">
    <button class="kes-lb-close" id="kes-lb-close" aria-label="Tutup">✕</button>
    <img id="kes-lb-img" src="" alt="" class="kes-lb-img" />
    <div class="kes-lb-cap" id="kes-lb-cap"></div>
  </div>
</div>

<style>
  :root {
    --clr-gray-400: #9ca3af;
    --clr-gray-500: #6b7280;
    --clr-gray-700: #374151;
    --clr-gray-800: #1f2937;
  }

  .section-sehat {
    background: #f8fafc;
    padding: 4rem 0;
  }

  /* ===== Sub-section Shared Header ===== */
  .sub-section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .sub-eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #059669;
    margin-bottom: 0.3rem;
  }
  .sub-title {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--clr-gray-800);
    margin: 0;
  }
  .sub-note {
    font-size: 0.75rem;
    color: var(--clr-gray-500);
    margin: 0;
    align-self: flex-end;
  }

  /* ===== Live Survey Stats Widget ===== */
  .live-survey-wrap {
    background: #fff;
    border-radius: 1.25rem;
    border: 1px solid rgba(16,185,129,.2);
    box-shadow: 0 10px 25px -5px rgba(16,185,129,.1);
    overflow: hidden;
    margin-bottom: 2.5rem;
  }
  .live-survey-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
    border-bottom: 1px solid rgba(16,185,129,.15);
    flex-wrap: wrap; gap: 0.5rem;
  }
  .live-survey-title {
    display: flex; align-items: center; gap: 0.75rem;
    font-size: 0.95rem; color: #064e3b;
  }
  .live-survey-sub { font-size: 0.75rem; color: #047857; font-weight: 500; opacity: 0.8; }
  .live-dot {
    width: 10px; height: 10px; background: #10b981; border-radius: 50%;
    box-shadow: 0 0 0 4px rgba(16,185,129,.25);
    animation: livePulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes livePulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(16,185,129,.25); }
    50%       { box-shadow: 0 0 0 8px rgba(16,185,129,.1); }
  }
  .live-survey-status {
    font-size: 0.75rem; font-weight: 700; color: #065f46;
    background: #d1fae5; padding: 0.3rem 0.8rem;
    border-radius: 99px; border: 1px solid #a7f3d0;
    white-space: nowrap;
  }
  .live-survey-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  }

  /* JS-injected stat card elements */
  :global(.kes-stat-card) {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 1.5rem 1rem; border-right: 1px solid #f1f5f9;
    text-align: center; transition: background 0.3s ease;
  }
  :global(.kes-stat-card:last-child) { border-right: none; }
  :global(.kes-stat-card:hover) { background: #f0fdf4; }
  :global(.kes-stat-icon) { font-size: 1.75rem; margin-bottom: 0.5rem; }
  :global(.kes-stat-val) { font-size: 1.75rem; font-weight: 900; line-height: 1.1; margin-bottom: 0.25rem; }
  :global(.kes-stat-lbl) { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--clr-gray-400); margin-bottom: 0.5rem; }
  :global(.kes-stat-badge) { font-size: 0.65rem; font-weight: 700; padding: 0.25rem 0.6rem; border-radius: 99px; }
  :global(.ks-green)  { background: #d1fae5; color: #065f46; }
  :global(.ks-red)    { background: #fee2e2; color: #991b1b; }
  :global(.ks-yellow) { background: #fef3c7; color: #92400e; }
  :global(.ks-blue)   { background: #dbeafe; color: #1e40af; }
  :global(.ks-purple) { background: #ede9fe; color: #5b21b6; }

  /* Skeletons */
  .kes-stat-skeleton {
    height: 120px;
    background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.5s infinite;
    border-right: 1px solid #fff;
  }
  @keyframes skeletonShimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ===== Prevalensi Section ===== */
  .prevalensi-wrap {
    background: #fff;
    border-radius: 1.25rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 20px -5px rgba(0,0,0,0.06);
    padding: 1.75rem;
    margin-bottom: 2.5rem;
  }
  .prevalensi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .prev-skeleton {
    height: 160px;
    border-radius: 0.75rem;
    background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.5s infinite;
  }

  /* JS-injected prevalensi card elements */
  :global(.prev-card) {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.875rem;
    padding: 1.1rem 1.25rem;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  :global(.prev-card:hover) {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -5px rgba(0,0,0,0.08);
  }
  :global(.prev-card-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  :global(.prev-rw) {
    font-size: 0.95rem;
    font-weight: 800;
    color: #1e3a5f;
    background: linear-gradient(135deg, #dbeafe, #e0f2fe);
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    border: 1px solid #bfdbfe;
  }
  :global(.prev-total) {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--clr-gray-500);
  }
  :global(.prev-bar-wrap) { margin-bottom: 0.65rem; }
  :global(.prev-bar-label) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    color: var(--clr-gray-500);
    margin-bottom: 0.3rem;
  }
  :global(.prev-bar-label strong) { font-size: 0.85rem; }
  :global(.prev-bar-track) {
    height: 8px;
    background: #f1f5f9;
    border-radius: 99px;
    overflow: hidden;
  }
  :global(.prev-bar-fill) {
    height: 100%;
    border-radius: 99px;
    transition: width 1.2s cubic-bezier(0.25, 1, 0.5, 1);
  }
  :global(.prev-bar-karies)  { background: linear-gradient(90deg, #dc2626, #f87171); }
  :global(.prev-bar-stunting) { background: linear-gradient(90deg, #f97316, #fb923c); }
  :global(.prev-card-footer) {
    font-size: 0.7rem;
    color: var(--clr-gray-400);
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid #f1f5f9;
  }

  /* Shimmer Loading placeholders */
  .kes-shimmer-text {
    display: inline-block;
    height: 1rem;
    width: 50px;
    background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
    background-size: 200% 100%;
    animation: skeletonShimmer 1.5s infinite;
    border-radius: 4px;
    vertical-align: middle;
  }
  .kes-shimmer-long {
    width: 150px;
    height: 0.85rem;
  }

  /* ===== Health Cards Grid ===== */
  .health-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .health-card {
    background: #ffffff;
    border-radius: 1.25rem;
    padding: 1.75rem;
    position: relative;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex; flex-direction: column;
  }
  .health-card::before {
    content: ''; position: absolute;
    top: 0; left: 0; right: 0; height: 5px;
    background: var(--card-accent);
    border-radius: 1.25rem 1.25rem 0 0;
  }
  .health-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 25px -5px rgba(0,0,0,0.1);
  }
  .health-card-icon {
    width: 48px; height: 48px;
    background: var(--icon-bg);
    border-radius: 12px;
    display: grid; place-items: center;
    font-size: 1.5rem; margin-bottom: 1.25rem;
  }
  .health-card-eyebrow {
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
    color: var(--clr-gray-400); letter-spacing: 0.05em; margin-bottom: 0.25rem;
  }
  .health-card-title {
    font-size: 1.25rem; font-weight: 800; color: var(--clr-gray-800);
    margin-bottom: 1.25rem; line-height: 1.3;
  }

  /* Pictograms */
  .pictogram-row { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.75rem; }
  .pictogram-item { font-size: 1.5rem; line-height: 1; transition: transform 0.2s; }
  .pictogram-item:hover { transform: scale(1.2); }
  .pictogram-label { font-size: 0.9rem; color: var(--clr-gray-700); line-height: 1.5; margin-bottom: 1rem; }

  /* Ring Charts */
  .pct-ring-wrap { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1rem; }
  .pct-ring { width: 80px; height: 80px; flex-shrink: 0; }
  .ring-animate { transition: stroke-dashoffset 2s cubic-bezier(0.25, 1, 0.5, 1); }
  .pct-ring-text { flex: 1; }
  .pct-ring-value { font-size: 2rem; font-weight: 900; line-height: 1; margin-bottom: 0.25rem; }
  .pct-ring-desc { font-size: 0.85rem; color: var(--clr-gray-500); line-height: 1.4; }

  /* Flow Chart */
  .flow-chart { background: #f8fafc; border-radius: 12px; padding: 1.25rem; text-align: center; }
  .flow-start { font-weight: 700; color: var(--clr-gray-800); font-size: 0.95rem; }
  .flow-arrow { font-size: 1.25rem; color: var(--clr-gray-400); margin: 0.5rem 0; }
  .flow-branches { display: flex; gap: 1rem; justify-content: center; margin-bottom: 1rem; }
  .flow-node { flex: 1; padding: 0.75rem; border-radius: 8px; font-size: 0.8rem; font-weight: 600; display: flex; flex-direction: column; align-items: center; gap: 0.25rem; }
  .flow-node-primary { background: #ecfccb; border: 1px solid #bef264; color: #3f6212; }
  .flow-node-secondary { background: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; }
  .node-icon { font-size: 1.25rem; }
  .flow-pct { font-size: 1.25rem; font-weight: 900; margin-top: 0.25rem; }
  .flow-note { font-size: 0.75rem; color: #047857; background: #d1fae5; padding: 0.5rem; border-radius: 6px; }

  /* KIA / Posyandu */
  .kia-highlight { display: flex; align-items: center; gap: 1rem; background: #f5f3ff; padding: 1rem; border-radius: 12px; border: 1px solid #ddd6fe; margin-bottom: 1.25rem; }
  .kia-big-num { font-size: 2.5rem; font-weight: 900; color: #7c3aed; line-height: 1; }
  .kia-text strong { display: block; font-size: 0.95rem; color: #5b21b6; margin-bottom: 0.25rem; }
  .kia-text span { font-size: 0.8rem; color: #7c3aed; line-height: 1.4; display: block; }
  .kia-children-row { display: flex; gap: 0.5rem; justify-content: center; font-size: 1.75rem; margin-bottom: 1rem; }
