---
// Komoditas.astro
---

<!-- Wave Divider (from toga to komoditas) -->
<div class="wave-divider" aria-hidden="true" style="background:var(--clr-mist);">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,0 C480,60 960,0 1440,40 L1440,60 L0,60 Z" fill="var(--clr-gray-800)"/>
  </svg>
</div>

<section class="section section-komoditas" id="komoditas" aria-labelledby="komoditas-title">
  <div class="container" style="position:relative;z-index:1;">

    <header class="section-header">
      <span
        class="eyebrow"
        style="background:rgba(160,98,42,0.2);color:var(--clr-coffee-300);"
      >
        ☕ Komoditas Unggulan
      </span>
      <h2 class="section-title" id="komoditas-title">
        Kekayaan Bumi <span>Gunung Dempo</span>
      </h2>
      <p class="section-desc" style="color:rgba(255,255,255,0.65);">
        Dua komoditas andalan yang menjadi tulang punggung perekonomian dan identitas
        kelurahan di kaki Gunung Dempo.
      </p>
    </header>

    <div class="komoditas-grid">

      <article class="komoditas-card reveal reveal-delay-1" id="komoditas-kopi">
        <span class="komoditas-emoji" aria-hidden="true">☕</span>
        <h3 class="komoditas-name">Kopi Dempo</h3>
        <p class="komoditas-desc">
          Ditanam di ketinggian 1.000–1.600 mdpl, kopi Dempo dikenal dengan cita rasa
          earthy, full body, dan sedikit cokelat alami yang khas.
        </p>
        <div class="komoditas-stat">±934 ha</div>
        <div class="komoditas-stat-label">Luas Lahan Kopi</div>
      </article>

      <article class="komoditas-card reveal reveal-delay-2" id="komoditas-teh">
        <span class="komoditas-emoji" aria-hidden="true">🍵</span>
        <h3 class="komoditas-name">Teh Pegunungan</h3>
        <p class="komoditas-desc">
          Perkebunan teh membentang di lereng Gunung Dempo, menghasilkan teh premium
          dengan aroma segar pegunungan dan kandungan antioksidan tinggi.
        </p>
        <div class="komoditas-stat">±1500 ha</div>
        <div class="komoditas-stat-label">Luas Lahan Teh</div>
      </article>

      <article class="komoditas-card reveal reveal-delay-3" id="komoditas-toga-prod">
        <span class="komoditas-emoji" aria-hidden="true">🌿</span>
        <h3 class="komoditas-name">Produk Olahan TOGA</h3>
        <p class="komoditas-desc">
          Inisiatif KKNT 103 Kelompok 25 membantu warga mengolah tanaman TOGA menjadi
          minuman herbal, dan produk herbal yang siap dipasarkan.
        </p>
        <div class="komoditas-stat">3 Jenis</div>
        <div class="komoditas-stat-label">Produk Unggulan TOGA</div>
      </article>

    </div>

    <!-- Coffee & Tea Banner Image -->
    <div
      class="reveal"
      style="margin-top:3rem;border-radius:var(--radius-xl);overflow:hidden;box-shadow:var(--shadow-xl);max-height:260px;"
    >
      <img
        src="/images/coffee_tea.png"
        alt="Biji kopi robusta dan daun teh hijau khas Gunung Dempo"
        style="width:100%;height:260px;object-fit:cover;object-position:center;"
        loading="lazy"
        width="1200"
        height="400"
      />
    </div>

  </div>
</section>
